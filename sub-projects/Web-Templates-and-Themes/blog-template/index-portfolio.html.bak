            <div class="absolute bottom-2 left-2 text-yellow-600/30 text-xs"><i class="fa-solid fa-feather-pointed"></i></div>
            <div class="absolute bottom-2 right-2 text-yellow-600/30 text-xs"><i class="fa-solid fa-feather-pointed"></i></div>

            <!-- Gold Ribbon Badge -->
