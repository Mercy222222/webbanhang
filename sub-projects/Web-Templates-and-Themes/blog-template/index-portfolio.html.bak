    /* â”€â”€â”€ DANH SÃCH SKILLS (YS ARRAY) â”€â”€â”€ */
    const YS = [
      { icon: "<i class='devicon-html5-plain colored'></i>", label: "HTML" },
      { icon: "<i class='devicon-css3-plain colored'></i>", label: "CSS" },
      { icon: "<i class='devicon-javascript-plain colored'></i>", label: "JavaScript" },
      { icon: "<i class='devicon-php-plain colored'></i>", label: "PHP" },
      { icon: "<i class='devicon-mysql-plain colored'></i>", label: "MySQL" },
      { icon: "<i class='devicon-bootstrap-plain colored'></i>", label: "Bootstrap" },
      { icon: "<i class='devicon-tailwindcss-plain colored'></i>", label: "TailwindCSS" },
      { icon: "<i class='devicon-photoshop-plain colored'></i>", label: "Photoshop" },
      { icon: "<i class='devicon-premierepro-plain colored'></i>", label: "Premiere Pro" },
      { icon: "<i class='devicon-figma-plain colored'></i>", label: "Figma" },
      { icon: "<i class='devicon-git-plain colored'></i>", label: "Git" },
      { icon: "<i class='devicon-nodejs-plain colored'></i>", label: "NodeJS" },
      { icon: "<i class='devicon-express-original colored'></i>", label: "ExpressJS" },
      { icon: "<i class='devicon-mongodb-plain colored'></i>", label: "MongoDB" }
    ];

    /* â”€â”€â”€ QUáº¢N LÃ TRáº NG THÃI (STATE MANAGEMENT) â”€â”€â”€ */
    let currentLanguage = localStorage.getItem('portfolio_lang') || 'vi';
    let currentTheme = localStorage.getItem('portfolio_theme') || 'dark';

    // HÃ m láº¥y chuá»—i dá»‹ch thuáº­t
    function t(key) {
      return W2[currentLanguage][key] || key;
    }

    /* â”€â”€â”€ KHá»žI Táº O HIá»†U á»¨NG GIAO DIá»†N (UI EFFECTS) â”€â”€â”€ */
    
    // 1. Táº¡o kÃ­ tá»± code bay lÆ¡ lá»­ng á»Ÿ Hero section
    function initCodeSymbols() {
      const container = document.getElementById('code-symbols-container');
      if (!container) return;
      container.innerHTML = '';
      const symbols = ["<", ">", "{", "}", "(", ")", ";", "=", "+", "-", "*", "/", "&&", "||", "!="];
      symbols.forEach((sym, idx) => {
        const div = document.createElement('div');
        div.className = 'absolute font-bold code-symbol-float select-none';
        div.textContent = sym;
        
        const size = Math.floor(Math.random() * 12) + 14;
        const color = Math.random() > 0.5 ? 'rgba(59, 130, 246, 0.4)' : 'rgba(16, 185, 129, 0.4)';
        const left = Math.random() * 90;
        const top = Math.random() * 80;
        const animNum = (idx % 3) + 1;
        const duration = (3 + Math.random() * 2).toFixed(2);
        const delay = (Math.random() * 2).toFixed(2);

        div.style.fontSize = `${size}px`;
        div.style.color = color;
        div.style.left = `${left}%`;
        div.style.top = `${top}%`;
        div.style.animationName = `codeFloat${animNum}`;
        div.style.animationDuration = `${duration}s`;
        div.style.animationDelay = `${delay}s`;
        div.style.animationIterationCount = 'infinite';
        div.style.animationTimingFunction = 'ease-in-out';

        container.appendChild(div);
      });
    }

    // 2. Táº¡o mÆ°a nhá»‹ phÃ¢n rÆ¡i tá»± do
    function initBinaryRain() {
      const container = document.getElementById('binary-rain-container');
      if (!container) return;
      container.innerHTML = '';
      const columns = 8;
      for (let i = 0; i < columns; i++) {
        const div = document.createElement('div');
        div.className = 'absolute binary-column-anim text-cyan-400/30 select-none font-bold';
        
        const left = 10 + i * 12;
        const duration = (2 + Math.random()).toFixed(2);
        const delay = (Math.random() * 2).toFixed(2);
        
        div.style.left = `${left}%`;
        div.style.animationDuration = `${duration}s`;
        div.style.animationDelay = `${delay}s`;
        
        // chuá»—i nhá»‹ phÃ¢n ngáº«u nhiÃªn
        div.textContent = Math.random().toString(2).substring(2, 9);
        
        container.appendChild(div);
      }
    }

    /* â”€â”€â”€ Káº¾T XUáº¤T Dá»® LIá»†U Äá»˜NG (DYNAMIC RENDERING) â”€â”€â”€ */

    // Render Ká»¹ nÄƒng (Skills Grid)
    function renderSkills() {
      const container = document.getElementById('skills-grid-container');
      if (!container) return;
      container.innerHTML = '';

      YS.forEach((skill) => {
        const card = document.createElement('div');
        // Class CSS phá»‘i há»£p mÃ u viá»n vÃ  ná»n Ä‘á»™ng khi Ä‘á»•i Theme
        card.className = `skill-card flex items-center gap-4 px-6 py-4 rounded-xl border transition-all duration-500 transform hover:scale-105 opacity-0 translate-y-[30px] cursor-pointer
          border-zinc-200 bg-white hover:bg-zinc-50 dark: dark:bg-black/40 dark:hover:bg-emerald-900/10`;
        
        // ThÃªm sá»± kiá»‡n hover phÃ¡t sÃ¡ng viá»n xanh
        card.onmouseenter = (e) => {
          e.currentTarget.style.boxShadow = '0 0 20px rgba(0, 123, 255, 0.25)';
          e.currentTarget.style.borderColor = '#007bff';
        };
        card.onmouseleave = (e) => {
          e.currentTarget.style.boxShadow = '';
          e.currentTarget.style.borderColor = '';
        };

        const iconWrap = document.createElement('span');
        iconWrap.className = 'text-3xl flex items-center justify-center parallax-high';
        iconWrap.innerHTML = skill.icon;

        const label = document.createElement('span');
        label.className = 'text-base font-semibold tracking-wide parallax-mid';
        label.textContent = skill.label;

        card.appendChild(iconWrap);
        card.appendChild(label);
        container.appendChild(card);
      });
      init3DTilt();
    }

    // Render Kinh nghiá»‡m lÃ m viá»‡c (Experience Timeline)
    function renderExperience() {
      const container = document.getElementById('experience-list-container');
      if (!container) return;
      container.innerHTML = '';

      const workList = W2[currentLanguage].workExperience || [];
      if (workList.length === 0) {
        container.innerHTML = `<p class="text-center py-8 text-zinc-500">${currentLanguage === 'vi' ? 'ChÆ°a cÃ³ kinh nghiá»‡m nÃ o.' : 'No experience listed.'}</p>`;
        return;
      }

      const isVisible = document.getElementById('workExp')?.classList.contains('visible');
      workList.forEach((work) => {
        const card = document.createElement('div');
        card.className = `work-card bg-zinc-50 dark:bg-black/20 rounded-2xl border border-zinc-200/50 dark:/50 p-6 md:p-8 hover:shadow-xl transition-all duration-500 transform ${isVisible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-[30px]'}`;
        
        card.onmouseenter = (e) => {
          e.currentTarget.style.boxShadow = '0 10px 30px rgba(0, 123, 255, 0.1)';
          e.currentTarget.style.borderColor = '#007bff';
        };
        card.onmouseleave = (e) => {
          e.currentTarget.style.boxShadow = '';
          e.currentTarget.style.borderColor = '';
        };

        const durationBadgeText = (work.duration.includes('Present') || work.duration.includes('Hiá»‡n táº¡i')) 
          ? (currentLanguage === 'vi' ? 'Hiá»‡n táº¡i' : 'Current') 
          : (currentLanguage === 'vi' ? 'ÄÃ£ hoÃ n thÃ nh' : 'Completed');

        const badgeClass = (work.duration.includes('Present') || work.duration.includes('Hiá»‡n táº¡i'))
          ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-200'
          : 'bg-zinc-100 text-zinc-800 dark:securify-card dark:text-zinc-300';

        let responsibilitiesHTML = '';
        work.responsibilities.forEach((resp) => {
          responsibilitiesHTML += `
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mt-2 flex-shrink-0"></span>
              <span class="text-sm md:text-base text-zinc-600 dark:text-zinc-300">${resp}</span>
            </li>
          `;
        });

        let achievementsHTML = '';
        work.achievements.forEach((ach) => {
          achievementsHTML += `
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mt-2 flex-shrink-0"></span>
              <span class="text-sm md:text-base text-zinc-600 dark:text-zinc-300">${ach}</span>
            </li>
          `;
        });

        card.innerHTML = `
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
            <div class="parallax-high">
              <h3 class="text-xl md:text-2xl font-bold mb-1">${work.position}</h3>
              <h4 class="text-md md:text-lg font-semibold text-cyan-400 mb-2">${work.company}</h4>
              <div class="flex flex-wrap items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400 font-medium parallax-low">
                <span class="flex items-center gap-1.5"><i class="far fa-calendar-alt"></i> ${work.duration}</span>
                <span class="hidden sm:inline">â€¢</span>
                <span class="flex items-center gap-1.5"><i class="fas fa-map-marker-alt"></i> ${work.location}</span>
              </div>
            </div>
            <div class="flex-shrink-0 parallax-mid">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold uppercase ${badgeClass}">
                <span class="w-2 h-2 rounded-full mr-2 ${work.duration.includes('Present') || work.duration.includes('Hiá»‡n táº¡i') ? 'bg-emerald-500 animate-pulse' : 'bg-zinc-400'}"></span>
                ${durationBadgeText}
              </span>
            </div>
          </div>

          <div class="mb-6 parallax-low">
            <p class="text-zinc-600 dark:text-zinc-300 text-sm md:text-base leading-relaxed">${work.description}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-zinc-200/50 dark:/50 parallax-mid">
            <div>
              <h5 class="text-sm font-bold  text-cyan-400 mb-3 flex items-center gap-2">
                <i class="fas fa-tasks"></i> ${currentLanguage === 'vi' ? 'TrÃ¡ch nhiá»‡m chÃ­nh' : 'Key Responsibilities'}
              </h5>
              <ul class="space-y-2.5">${responsibilitiesHTML}</ul>
            </div>
            <div>
              <h5 class="text-sm font-bold  text-cyan-400 mb-3 flex items-center gap-2">
                <i class="fas fa-trophy"></i> ${currentLanguage === 'vi' ? 'ThÃ nh tá»±u Ä‘áº¡t Ä‘Æ°á»£c' : 'Key Achievements'}
              </h5>
              <ul class="space-y-2.5">${achievementsHTML}</ul>
            </div>
          </div>
        `;

        container.appendChild(card);
      });
      init3DTilt();
    }

    // Render Chá»©ng chá»‰ (Certificates Grid)
    function renderCertificates() {
      const container = document.getElementById('certificates-grid-container');
      if (!container) return;
      container.innerHTML = '';

      const certs = W2[currentLanguage].certificates || [];
      const isVisible = document.getElementById('certificates')?.classList.contains('visible');
      certs.forEach((cert) => {
        const card = document.createElement('div');
        card.className = `certificate-card bg-zinc-50 dark:bg-black/20 rounded-xl border border-zinc-200/50 dark:/50 p-5 flex flex-col justify-between transition-all duration-300 hover:scale-105 ${isVisible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-[30px]'}`;
        
        card.onmouseenter = (e) => {
          e.currentTarget.style.boxShadow = '0 8px 25px rgba(0, 123, 255, 0.15)';
          e.currentTarget.style.borderColor = '#007bff';
        };
        card.onmouseleave = (e) => {
          e.currentTarget.style.boxShadow = '';
          e.currentTarget.style.borderColor = '';
        };

        card.innerHTML = `
          <div class="space-y-3">
            <div class="text-3xl text-cyan-400 parallax-high"><i class="fas fa-certificate"></i></div>
            <h3 class="text-base font-bold tracking-tight parallax-mid">${cert.title}</h3>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 font-semibold parallax-low">${cert.issuer} â€¢ ${cert.date}</p>
            <div class="inline-block px-2.5 py-0.5 rounded bg-zinc-200 dark:securify-card text-[10px] font-mono text-zinc-500 dark:text-zinc-400 uppercase parallax-low">
          <div class="glare"></div>
              ID: ${cert.id_code}
            </div>
          </div>
          <button onclick="showCertAlert('${cert.title}', '${cert.issuer}', '${cert.date}', '${cert.id_code}')" class="mt-5 w-full py-2 rounded font-semibold text-xs transition border border-zinc-300 dark:border-zinc-700 hover:bg-cyan-500 hover:text-white hover:border-emerald-600 parallax-high">
            ${t('certiDetail')}
          </button>
        `;
        container.appendChild(card);
      });
      init3DTilt();
    }

    // Popup xem chi tiáº¿t chá»©ng chá»‰
    function showCertAlert(title, issuer, date, id_code) {
