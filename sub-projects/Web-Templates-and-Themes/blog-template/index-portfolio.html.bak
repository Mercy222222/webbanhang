        if (btnEnMob) btnEnMob.className = `px-2.5 py-1 rounded-md text-xs font-extrabold uppercase transition-all duration-300 ${inactiveClass}`;
      } else {
        if (btnVi) btnVi.className = `px-2.5 py-1 rounded-md text-xs font-extrabold uppercase transition-all duration-300 ${inactiveClass}`;
        if (btnEn) btnEn.className = `px-2.5 py-1 rounded-md text-xs font-extrabold uppercase transition-all duration-300 ${activeClass}`;
        if (btnViMob) btnViMob.className = `px-2.5 py-1 rounded-md text-xs font-extrabold uppercase transition-all duration-300 ${inactiveClass}`;
        if (btnEnMob) btnEnMob.className = `px-2.5 py-1 rounded-md text-xs font-extrabold uppercase transition-all duration-300 ${activeClass}`;
