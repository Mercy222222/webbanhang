        <div class="gs-reveal-up flex-1 bg-zinc-50 dark:bg-black/20 border border-zinc-200/50 dark:border-white/[0.07] rounded-2xl p-6 md:p-8 shadow-sm backdrop-blur-sm">
          <h4 id="label-contact-subtitle" class="text-sm font-semibold text-zinc-500 dark:text-zinc-400  mb-6">
            <!-- Fill out form -->
          </h4>

          <form id="contact-form" onsubmit="handleContactSubmit(event)" class="space-y-5">
            <!-- Name Input -->
            <div class="space-y-1.5">
              <label for="contact-name" id="form-label-name" class="block text-sm font-semibold uppercase text-zinc-500 dark:text-zinc-400 tracking-wider"></label>
              <input type="text" id="contact-name" name="name" class="w-full bg-white dark:bg-black/50 border border-zinc-300 dark:border-zinc-700 rounded-lg py-2.5 px-4 text-sm outline-none transition-all duration-300 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-400/20 dark:text-white" />
              <p id="error-name" class="text-xs text-red-500 font-medium hidden"></p>
            </div>

            <!-- Email Input -->
            <div class="space-y-1.5">
              <label for="contact-email" id="form-label-email" class="block text-sm font-semibold uppercase text-zinc-500 dark:text-zinc-400 tracking-wider"></label>
              <input type="email" id="contact-email" name="email" class="w-full bg-white dark:bg-black/50 border border-zinc-300 dark:border-zinc-700 rounded-lg py-2.5 px-4 text-sm outline-none transition-all duration-300 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-400/20 dark:text-white" />
              <p id="error-email" class="text-xs text-red-500 font-medium hidden"></p>
            </div>

            <!-- Phone Input -->
            <div class="space-y-1.5">
              <label for="contact-phone" id="form-label-phone" class="block text-sm font-semibold uppercase text-zinc-500 dark:text-zinc-400 tracking-wider"></label>
              <input type="tel" id="contact-phone" name="phone" class="w-full bg-white dark:bg-black/50 border border-zinc-300 dark:border-zinc-700 rounded-lg py-2.5 px-4 text-sm outline-none transition-all duration-300 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-400/20 dark:text-white" />
              <p id="error-phone" class="text-xs text-red-500 font-medium hidden"></p>
            </div>

            <!-- Message Input -->
            <div class="space-y-1.5">
              <label for="contact-message" id="form-label-message" class="block text-sm font-semibold uppercase text-zinc-500 dark:text-zinc-400 tracking-wider"></label>
              <textarea id="contact-message" name="message" rows="4" class="w-full bg-white dark:bg-black/50 border border-zinc-300 dark:border-zinc-700 rounded-lg py-2.5 px-4 text-sm outline-none transition-all duration-300 focus:border-cyan-400 focus:ring-2 focus:ring-cyan-400/20 dark:text-white resize-none"></textarea>
              <p id="error-message" class="text-xs text-red-500 font-medium hidden"></p>
            </div>

            <!-- Submit Button -->
            <button type="submit" id="btn-contact-submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-cyan-500 to-emerald-500 hover:from-cyan-400 hover:to-emerald-400 text-white font-bold transition-all duration-300 shadow-lg hover:shadow-cyan-500/30 hover:-translate-y-0.5 active:scale-[0.98] flex justify-center items-center gap-2">
              <!-- Send -->
            </button>
          </form>
