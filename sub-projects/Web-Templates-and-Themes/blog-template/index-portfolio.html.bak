          <div class="relative border-4 border-double border-yellow-600 bg-amber-50/5 dark:bg-slate-900/60 p-6 rounded-xl text-center font-serif text-slate-800 dark:text-slate-100 max-w-full overflow-hidden shadow-2xl mt-4">
