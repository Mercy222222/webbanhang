    function setLanguage(lang) {
      currentLanguage = lang;
      localStorage.setItem('portfolio_lang', currentLanguage);
      updateLanguageUI();
    }

    function toggleLanguage() {
      currentLanguage = currentLanguage === 'vi' ? 'en' : 'vi';
      localStorage.setItem('portfolio_lang', currentLanguage);
      updateLanguageUI();
    }

    /* â”€â”€â”€ PROCEDURAL HUD AUDIO SYNTHESIZER (WEB AUDIO API) â”€â”€â”€ */
    let audioCtx = null;
    let isAudioMuted = true;

    function initAudio() {
      if (audioCtx) return;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }

    function toggleMute() {
      initAudio();
      isAudioMuted = !isAudioMuted;
      
      const icon = document.getElementById('audio-icon');
      const btn = document.getElementById('btn-audio');
      
      if (isAudioMuted) {
        icon.className = 'fas fa-volume-mute';
        btn.classList.add('text-zinc-400');
        btn.classList.remove('text-cyan-400');
      } else {
        icon.className = 'fas fa-volume-up';
        btn.classList.remove('text-zinc-400');
        btn.classList.add('text-cyan-400', 'border-cyan-400/50');
        
        // Play wake-up chime
        playChime();
      }
    }

    function playTick() {
      if (isAudioMuted || !audioCtx) return;
      
      // Short hover click sound
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(1400, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(120, audioCtx.currentTime + 0.04);
      
      gain.gain.setValueAtTime(0.035, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.04);
      
      osc.start();
      osc.stop(audioCtx.currentTime + 0.04);
    }

    function playPulse() {
      if (isAudioMuted || !audioCtx) return;
      
      // Short click sweep
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(240, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(30, audioCtx.currentTime + 0.12);
      
      gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.12);
      
      osc.start();
      osc.stop(audioCtx.currentTime + 0.12);
    }

    function playChime() {
      if (isAudioMuted || !audioCtx) return;
      
      const now = audioCtx.currentTime;
      const notes = [523.25, 659.25, 783.99, 1046.50]; // C5, E5, G5, C6
      
      notes.forEach((freq, idx) => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, now + idx * 0.06);
        
        gain.gain.setValueAtTime(0.0, now + idx * 0.06);
        gain.gain.linearRampToValueAtTime(0.04, now + idx * 0.06 + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.06 + 0.22);
        
        osc.start(now + idx * 0.06);
        osc.stop(now + idx * 0.06 + 0.23);
      });
    }

    // Play a premium arpeggiated welcoming chime chord
    function playWelcomeChime() {
      if (isAudioMuted || !audioCtx) return;

      const now = audioCtx.currentTime;
      // Ascending C Major chord arpeggio: C4 (261.63Hz), E4 (329.63Hz), G4 (392.00Hz), C5 (523.25Hz), E5 (659.25Hz), G5 (783.99Hz), C6 (1046.50Hz)
      const freqs = [261.63, 329.63, 392.00, 523.25, 659.25, 783.99, 1046.50];
      
      freqs.forEach((freq, idx) => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        
        osc.type = 'triangle'; // triangle wave gives a warm synthesizer tone
        osc.frequency.setValueAtTime(freq, now + idx * 0.08);
        
        gain.gain.setValueAtTime(0.0, now + idx * 0.08);
        gain.gain.linearRampToValueAtTime(0.05, now + idx * 0.08 + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.08 + 0.8);
        
        osc.start(now + idx * 0.08);
        osc.stop(now + idx * 0.08 + 0.9);
      });
    }

    // Speak a welcoming message using Web Speech API Synthesis
    function speakWelcomeMessage() {
      if (isAudioMuted || !window.speechSynthesis) return;
      
      // Cancel any current speech
      window.speechSynthesis.cancel();
      
      let text = '';
      let lang = '';
      
      if (currentLanguage === 'vi') {
        text = 'ChÃ o má»«ng báº¡n Ä‘áº¿n vá»›i danh má»¥c há»“ sÆ¡ nÄƒng lá»±c cá»§a VÃµ Há»¯u TrÃ­!';
        lang = 'vi-VN';
      } else {
        text = 'Welcome to the portfolio of Vo Huu Tri!';
        lang = 'en-US';
      }
      
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = lang;
      utterance.rate = 0.95; // Slightly slower pace for clarity and professionalism
      utterance.pitch = 1.0;
      utterance.volume = 0.7;
      
      // Auto-select standard regional voice if possible
      const voices = window.speechSynthesis.getVoices();
      const matchVoice = voices.find(v => v.lang.startsWith(lang.split('-')[0])) || voices[0];
      if (matchVoice) {
        utterance.voice = matchVoice;
      }
      
      window.speechSynthesis.speak(utterance);
    }

    // Trigger welcoming audio arpeggio & speech on first user click/tap
    let welcomed = false;
    window.addEventListener('click', () => {
      if (!welcomed) {
        welcomed = true;
        
        // Initialize Audio context on user gesture (browser standard policy)
        initAudio();
        isAudioMuted = false;
        
        // Update Mute/Audio Button styling to Unmuted
        const icon = document.getElementById('audio-icon');
        const btn = document.getElementById('btn-audio');
        if (icon && btn) {
          icon.className = 'fas fa-volume-up';
          btn.classList.remove('text-zinc-400');
          btn.classList.add('text-cyan-400', 'border-cyan-400/50');
        }
        
        // Play the chime arpeggio and speak the welcome message
        playWelcomeChime();
        setTimeout(speakWelcomeMessage, 500); // Small offset after arpeggio arpeggiates
      }
    });

    /* â”€â”€â”€ CYBERPUNK SCRAMBLE TEXT EFFECT â”€â”€â”€ */
    function scrambleText(element, targetText) {
      if (!element) return;
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*()_-+=[]{}';
      let frame = 0;
      const totalFrames = 25;
      const originalText = targetText || element.innerText;
      
      function update() {
        let output = '';
        let complete = true;
        
        for (let i = 0; i < originalText.length; i++) {
          if (originalText[i] === ' ') {
            output += ' ';
            continue;
          }
          
          const trigger = (totalFrames / originalText.length) * i;
          if (frame >= trigger) {
            output += originalText[i];
          } else {
            output += chars[Math.floor(Math.random() * chars.length)];
            complete = false;
          }
        }
        
        element.innerText = output;
        
        if (!complete && frame < totalFrames) {
          frame++;
          requestAnimationFrame(update);
        } else {
          element.innerText = originalText;
        }
      }
      
      requestAnimationFrame(update);
    }

    /* â”€â”€â”€ THAY Äá»”I GIAO DIá»†N (THEME SWITCHER) â”€â”€â”€ */
    function initTheme() {
      if (currentTheme === 'dark') {
        document.documentElement.classList.add('dark');
        document.getElementById('btn-theme').innerHTML = '<i class="fas fa-sun text-yellow-400"></i>';
        document.getElementById('btn-theme-mobile').innerHTML = '<i class="fas fa-sun text-yellow-400"></i>';
      } else {
        document.documentElement.classList.remove('dark');
        document.getElementById('btn-theme').innerHTML = '<i class="fas fa-moon"></i>';
        document.getElementById('btn-theme-mobile').innerHTML = '<i class="fas fa-moon"></i>';
      }
    }

    function toggleTheme() {
      currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
      localStorage.setItem('portfolio_theme', currentTheme);
      initTheme();
    }

    /* â”€â”€â”€ HAMBURGER MENU CHO DI Äá»˜NG â”€â”€â”€ */
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      const burgerIcon = document.querySelector('#btn-hamburger i');
      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        burgerIcon.className = 'fas fa-times';
      } else {
        menu.classList.add('hidden');
        burgerIcon.className = 'fas fa-bars';
      }
    }

    function closeMobileMenu() {
      document.getElementById('mobile-menu').classList.add('hidden');
      document.querySelector('#btn-hamburger i').className = 'fas fa-bars';
    }

    /* â”€â”€â”€ Xá»¬ LÃ BIá»‚U MáºªU LIÃŠN Há»† & KIá»‚M TRA Lá»–I (CONTACT FORM VALIDATION) â”€â”€â”€ */
    function handleContactSubmit(event) {
      event.preventDefault();
      
      const form = event.target;
      const name = form.name.value.trim();
      const email = form.email.value.trim();
      const phone = form.phone.value.trim();
      const message = form.message.value.trim();
      
      let isValid = true;

      // 1. Kiá»ƒm tra TÃªn
      const errorName = document.getElementById('error-name');
      if (!name) {
        errorName.textContent = t('validation.nameRequired');
        errorName.classList.remove('hidden');
        isValid = false;
      } else if (name.length < 2) {
        errorName.textContent = t('validation.nameMin');
        errorName.classList.remove('hidden');
        isValid = false;
      } else {
        errorName.classList.add('hidden');
      }

      // 2. Kiá»ƒm tra Email
      const errorEmail = document.getElementById('error-email');
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!email) {
        errorEmail.textContent = t('validation.emailRequired');
        errorEmail.classList.remove('hidden');
        isValid = false;
      } else if (!emailRegex.test(email)) {
        errorEmail.textContent = t('validation.emailInvalid');
        errorEmail.classList.remove('hidden');
        isValid = false;
      } else {
        errorEmail.classList.add('hidden');
      }

      // 3. Kiá»ƒm tra Sá»‘ Ä‘iá»‡n thoáº¡i
      const errorPhone = document.getElementById('error-phone');
      const phoneRegex = /^[0-9]+$/;
      if (!phone) {
        errorPhone.textContent = t('validation.phoneRequired');
        errorPhone.classList.remove('hidden');
        isValid = false;
      } else if (!phoneRegex.test(phone)) {
        errorPhone.textContent = t('validation.phoneInvalid');
        errorPhone.classList.remove('hidden');
        isValid = false;
      } else if (phone.length < 10) {
        errorPhone.textContent = t('validation.phoneMin');
        errorPhone.classList.remove('hidden');
        isValid = false;
      } else {
        errorPhone.classList.add('hidden');
      }

      // 4. Kiá»ƒm tra Tin nháº¯n
      const errorMessage = document.getElementById('error-message');
      if (!message) {
        errorMessage.textContent = t('validation.messageRequired');
        errorMessage.classList.remove('hidden');
        isValid = false;
      } else if (message.length < 10) {
        errorMessage.textContent = t('validation.messageMin');
        errorMessage.classList.remove('hidden');
        isValid = false;
      } else {
        errorMessage.classList.add('hidden');
      }

      if (!isValid) return;

      // Hiá»‡u á»©ng gá»­i tin nháº¯n thÃ nh cÃ´ng
      const submitBtn = document.getElementById('btn-contact-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = t('contact.sending');

      setTimeout(() => {
        // Báº¯n phÃ¡o hoa Confetti chÃºc má»«ng
        confetti({
          particleCount: 150,
          spread: 80,
          origin: { y: 0.6 }
        });

        // BÃ¡o thÃ nh cÃ´ng báº±ng SweetAlert2
        Swal.fire({
          title: 'ðŸŽ‰ Send Success!',
          text: t('contact.successMessage'),
          icon: 'success',
          background: currentTheme === 'dark' ? 'rgba(24, 24, 24, 0.95)' : '#ffffff',
          color: currentTheme === 'dark' ? '#f5f5f5' : '#222222',
          confirmButtonColor: '#007bff'
        });

        form.reset();
        submitBtn.disabled = false;
        submitBtn.textContent = t('contact.send');
      }, 1500);
    }

    /* â”€â”€â”€ SCROLL REVEAL ANIMATIONS (INTERSECTION OBSERVER) â”€â”€â”€ */
    function initScrollReveal() {
      const observerOptions = {
        threshold: 0.15,
        rootMargin: '0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            
            // Scramble title text when entering viewport
            const titleSpan = entry.target.querySelector('span[id^="label-"]');
            if (titleSpan) {
              setTimeout(() => {
                scrambleText(titleSpan, titleSpan.innerText);
              }, 150);
            }
            
            // Náº¿u lÃ  má»¥c skills-grid, kÃ­ch hoáº¡t thÃªm hiá»‡u á»©ng xuáº¥t hiá»‡n tuáº§n tá»± cho cÃ¡c tháº» con
            if (entry.target.id === 'skills') {
              const cards = entry.target.querySelectorAll('.skill-card');
              cards.forEach((card, idx) => {
                setTimeout(() => {
                  card.classList.remove('opacity-0', 'translate-y-[30px]');
                }, idx * 100);
              });
            }

            // Kinh nghiá»‡m lÃ m viá»‡c xuáº¥t hiá»‡n tuáº§n tá»±
            if (entry.target.id === 'workExp') {
              const cards = entry.target.querySelectorAll('.work-card');
              cards.forEach((card, idx) => {
                setTimeout(() => {
                  card.classList.remove('opacity-0', 'translate-y-[30px]');
                }, idx * 200);
              });
            }

            // Chá»©ng chá»‰
            if (entry.target.id === 'certificates') {
              const cards = entry.target.querySelectorAll('.certificate-card');
              cards.forEach((card, idx) => {
                setTimeout(() => {
                  card.classList.remove('opacity-0', 'translate-y-[30px]');
                }, idx * 200);
              });
            }

            // Dá»± Ã¡n
            if (entry.target.id === 'projects') {
              const cards = entry.target.querySelectorAll('.project-card');
              cards.forEach((card, idx) => {
                setTimeout(() => {
                  card.classList.remove('opacity-0', 'translate-y-[30px]');
                }, idx * 150);
              });
            }

            observer.unobserve(entry.target); // Ngá»«ng theo dÃµi khi Ä‘Ã£ xuáº¥t hiá»‡n
          }
        });
      }, observerOptions);

      document.querySelectorAll('.reveal-item').forEach((item) => {
        observer.observe(item);
      });
    }

    // Shrink navbar and track active section on scroll
    let activeSectionName = 'home';
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (window.scrollY > 40) {
        nav.classList.add('h-[60px]', 'shadow-md');
        nav.classList.remove('h-[70px]');
      } else {
        nav.classList.add('h-[70px]');
        nav.classList.remove('h-[60px]', 'shadow-md');
      }

      // Track active section for background wave color shifting
      const scrollPos = window.scrollY + 250;
      const sections = ['home', 'about', 'workExp', 'skills', 'certificates', 'projects', 'contact'];
      for (const sect of sections) {
        const el = document.getElementById(sect);
        if (el) {
          const top = el.offsetTop;
          const height = el.offsetHeight;
          if (scrollPos >= top && scrollPos < top + height) {
            activeSectionName = sect;
            break;
          }
        }
      }
    });

    /* â”€â”€â”€ KHá»žI CHáº Y Há»† THá»NG KHI LOAD TRANG â”€â”€â”€ */
    window.addEventListener('DOMContentLoaded', () => {
      initTheme();
      updateLanguageUI();
      initCodeSymbols();
      initBinaryRain();
      renderSkills();
      initScrollReveal();
      
      // Initialize Three.js 3D Background
      initBackgroundThree();
      animateBackgroundThree();

      // Initialize 3D Hero Visual Box (Torus Knot)
      initHeroThree();
      animateHeroThree();
      
      // Initialize 3D Card Tilt
      init3DTilt();

      // Initialize Interactive Particle Cursor Trail
      initCursorTrail();

      // Initialize Magnetic Hover Buttons
      initMagneticButtons();

      // Initialize Scroll Progress and HUD elements
      initScrollProgressAndHUD();

      // Initialize Interactive Terminal HUD Console
      initTerminalHUD();
    });



    /* â”€â”€â”€ BRUTALIST 3D: ASCII TORUS & TERMINAL VOID â”€â”€â”€ */
    
    // ==========================================
    // 1. COSMIC UNIVERSE ECOSYSTEM (BACKGROUND)
    // ==========================================
    let bgScene, bgCamera, bgRenderer, bgComposer, bgClock;
    let bgMouseX = 0, bgMouseY = 0;

    // Orbital bodies storage
    const orbitals = [];       // { mesh, radius, speed, angle, inclination, pivot }
    const asteroids = [];
    const comets = [];
    const nebulaParticles = [];

    function initBackgroundThree() {
      const canvas = document.getElementById('global-3d-bg');
      if (!canvas) return;

      bgScene = new THREE.Scene();
      bgScene.fog = new THREE.FogExp2(0x00000a, 0.00018);

      const width = window.innerWidth;
      const height = window.innerHeight;

      bgCamera = new THREE.PerspectiveCamera(55, width / height, 1, 50000);
      bgCamera.position.set(0, 1200, 3200);
      bgCamera.lookAt(0, 0, 0);

      bgRenderer = new THREE.WebGLRenderer({ canvas, alpha: false, antialias: false, powerPreference: 'high-performance' });
      bgRenderer.setSize(width, height);
      bgRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
      bgScene.background = new THREE.Color(0x00000a);

      // â”€â”€â”€ BLOOM COMPOSER â”€â”€â”€
      const renderScene = new THREE.RenderPass(bgScene, bgCamera);
      const bloomPass = new THREE.UnrealBloomPass(new THREE.Vector2(width, height), 1.6, 0.7, 0.15);
      bgComposer = new THREE.EffectComposer(bgRenderer);
      bgComposer.addPass(renderScene);
      bgComposer.addPass(bloomPass);

      bgClock = new THREE.Clock();

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // A) CENTRAL BLACK HOLE (Singularity)
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // Event Horizon â€” pure void
      const bhGeo = new THREE.SphereGeometry(90, 48, 48);
      const bhMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
      bgScene.add(new THREE.Mesh(bhGeo, bhMat));

      // Gravitational lensing halo (multi-layer)
      [140, 100, 95].forEach((r, i) => {
        const colors = [0x06b6d4, 0x7c3aed, 0xff6600];
        const opacities = [0.08, 0.12, 0.18];
        const hGeo = new THREE.SphereGeometry(r, 32, 32);
        const hMat = new THREE.MeshBasicMaterial({
          color: colors[i], transparent: true, opacity: opacities[i],
          blending: THREE.AdditiveBlending, side: THREE.BackSide
        });
        bgScene.add(new THREE.Mesh(hGeo, hMat));
      });

      // Photon ring (cyan + orange dual ring)
      [[94, 4, 0x00ffff, 1.0], [100, 2.5, 0xff4400, 0.7], [88, 1.5, 0xffffff, 0.8]].forEach(([r, t, c, o]) => {
        const rGeo = new THREE.TorusGeometry(r, t, 16, 200);
        const rMat = new THREE.MeshBasicMaterial({ color: c, transparent: true, opacity: o, blending: THREE.AdditiveBlending });
        const ring = new THREE.Mesh(rGeo, rMat);
        ring.rotation.x = Math.PI / 2;
        bgScene.add(ring);
      });

      // â”€â”€â”€ ACCRETION DISK (GPU Shader â€” 15,000 particles) â”€â”€â”€
      const diskCount = 15000;
      const dPos = new Float32Array(diskCount * 3);
      const dColor = new Float32Array(diskCount * 3);
      const dSize = new Float32Array(diskCount);
      const dAngle = new Float32Array(diskCount);
      const dSpeed = new Float32Array(diskCount);
      const dRadius = new Float32Array(diskCount);

      for (let i = 0; i < diskCount; i++) {
        const r = 110 + Math.pow(Math.random(), 0.5) * 420;
        const a = Math.random() * Math.PI * 2;
        const h = (Math.random() - 0.5) * 40 * (1 - (r - 110) / 420);

        dPos[i*3] = Math.cos(a) * r;
        dPos[i*3+1] = h;
        dPos[i*3+2] = Math.sin(a) * r;
        dAngle[i] = a;
        dRadius[i] = r;
        dSpeed[i] = 0.3 + Math.random() * 0.7;
        dSize[i] = 1.2 + Math.random() * 2.5;

        // Temperature-based color: inner=white, middle=cyan, outer=deep blue
        const t = (r - 110) / 420;
        dColor[i*3]   = t < 0.3 ? 1.0 : (1.0 - t * 0.8);
        dColor[i*3+1] = t < 0.3 ? 1.0 : (0.7 - t * 0.3);
        dColor[i*3+2] = t < 0.5 ? 1.0 : (0.5 + t * 0.3);
      }

      const diskGeo = new THREE.BufferGeometry();
      diskGeo.setAttribute('position', new THREE.BufferAttribute(dPos, 3));
      diskGeo.setAttribute('color', new THREE.BufferAttribute(dColor, 3));
      diskGeo.setAttribute('size', new THREE.BufferAttribute(dSize, 1));
      diskGeo.setAttribute('pAngle', new THREE.BufferAttribute(dAngle, 1));
      diskGeo.setAttribute('pSpeed', new THREE.BufferAttribute(dSpeed, 1));
      diskGeo.setAttribute('pRadius', new THREE.BufferAttribute(dRadius, 1));

      const diskMat = new THREE.ShaderMaterial({
        uniforms: { time: { value: 0 } },
        vertexShader: `
          uniform float time;
          attribute float size;
          attribute float pAngle;
          attribute float pSpeed;
          attribute float pRadius;
          attribute vec3 color;
          varying vec3 vColor;
          varying float vAlpha;
          void main() {
            vColor = color;
            float angle = pAngle + time * pSpeed * 0.4 / sqrt(pRadius / 110.0);
            float warp = sin(angle * 3.0 + time * 0.5) * 8.0;
            vec3 pos = vec3(cos(angle) * pRadius, position.y + warp * 0.3, sin(angle) * pRadius);
            vAlpha = 1.0 - smoothstep(400.0, 530.0, pRadius);
            vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
            gl_PointSize = size * (600.0 / -mvPosition.z);
            gl_Position = projectionMatrix * mvPosition;
          }
        `,
        fragmentShader: `
          varying vec3 vColor;
          varying float vAlpha;
          void main() {
            vec2 xy = gl_PointCoord - 0.5;
            float r = length(xy);
            if (r > 0.5) discard;
            float alpha = exp(-r * r * 12.0) * vAlpha;
            gl_FragColor = vec4(vColor, alpha * 0.95);
          }
        `,
        transparent: true, blending: THREE.AdditiveBlending,
        depthWrite: false, vertexColors: true
      });
      const diskMesh = new THREE.Points(diskGeo, diskMat);
      bgScene.add(diskMesh);
      orbitals.push({ mesh: diskMesh, type: 'disk' });

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // B) GALAXY ARMS (Milky Way spiral â€” 30,000 stars)
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      const galCount = 30000;
      const gPos = new Float32Array(galCount * 3);
      const gCol = new Float32Array(galCount * 3);
      const gSizes = new Float32Array(galCount);
      const numArms = 4;
      const armOffset = (Math.PI * 2) / numArms;

      for (let i = 0; i < galCount; i++) {
        const arm = i % numArms;
        const progress = Math.pow(Math.random(), 0.6);
        const r = 600 + progress * 3500;
        const spin = progress * Math.PI * 5;
        const spread = Math.random() * 0.5;
        const angle = arm * armOffset + spin + (Math.random() - 0.5) * spread;

        gPos[i*3]   = Math.cos(angle) * r + (Math.random() - 0.5) * 150;
        gPos[i*3+1] = (Math.random() - 0.5) * 200 * (1 - progress * 0.7);
        gPos[i*3+2] = Math.sin(angle) * r + (Math.random() - 0.5) * 150;

        // Star colors: blue-white core, yellow-orange midrange, red periphery
        const t = progress;
        gCol[i*3]   = 0.5 + t * 0.5;
        gCol[i*3+1] = 0.6 - t * 0.2;
        gCol[i*3+2] = 1.0 - t * 0.8;
        gSizes[i] = 0.8 + Math.random() * 2.2;
      }

      const galGeo = new THREE.BufferGeometry();
      galGeo.setAttribute('position', new THREE.BufferAttribute(gPos, 3));
      galGeo.setAttribute('color', new THREE.BufferAttribute(gCol, 3));
      galGeo.setAttribute('size', new THREE.BufferAttribute(gSizes, 1));

      const galMat = new THREE.ShaderMaterial({
        uniforms: { time: { value: 0 } },
        vertexShader: `
          attribute float size;
          attribute vec3 color;
          varying vec3 vColor;
          varying float vAlpha;
          uniform float time;
          void main() {
            vColor = color;
            float dist = length(position.xz);
            vAlpha = 0.3 + 0.7 * (1.0 - smoothstep(3000.0, 4200.0, dist));
            // Subtle galaxy rotation
            float angle = atan(position.z, position.x) + time * 0.008 * (1.0 / (dist / 600.0 + 1.0));
            float r = length(position.xz);
            vec3 pos = vec3(cos(angle)*r, position.y, sin(angle)*r);
            vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
            gl_PointSize = size * (1000.0 / -mvPosition.z);
            gl_Position = projectionMatrix * mvPosition;
          }
        `,
        fragmentShader: `
          varying vec3 vColor;
          varying float vAlpha;
          void main() {
            vec2 xy = gl_PointCoord - 0.5;
            float r = length(xy);
            if (r > 0.5) discard;
            float a = exp(-r*r * 8.0) * vAlpha;
            gl_FragColor = vec4(vColor, a);
          }
        `,
        transparent: true, blending: THREE.AdditiveBlending,
        depthWrite: false, vertexColors: true
      });
      const galMesh = new THREE.Points(galGeo, galMat);
      bgScene.add(galMesh);
      orbitals.push({ mesh: galMesh, type: 'galaxy' });

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // C) SOLAR SYSTEM â€” 7 Planets + Moons
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      const planetDefs = [
        { r: 18, orbitR: 220, speed: 1.8,  color: 0xaaaaff, emissive: 0x3333aa, name: 'Mercury', inc: 0.05 },
        { r: 28, orbitR: 370, speed: 1.2,  color: 0xffcc88, emissive: 0xaa4400, name: 'Venus',   inc: 0.10 },
        { r: 32, orbitR: 550, speed: 0.9,  color: 0x3399ff, emissive: 0x001166, name: 'Earth',   inc: 0.02, hasMoon: true },
        { r: 22, orbitR: 720, speed: 0.7,  color: 0xff5533, emissive: 0x881100, name: 'Mars',    inc: 0.08 },
        { r: 70, orbitR: 980, speed: 0.45, color: 0xffcc77, emissive: 0x664400, name: 'Jupiter', inc: 0.03, hasRing: true },
        { r: 55, orbitR:1220, speed: 0.32, color: 0xddbb66, emissive: 0x553300, name: 'Saturn',  inc: 0.15, hasRing: true, bigRing: true },
        { r: 40, orbitR:1450, speed: 0.22, color: 0x66bbff, emissive: 0x003366, name: 'Uranus',  inc: 0.20 },
      ];

      planetDefs.forEach(def => {
        // Orbit pivot
        const pivot = new THREE.Object3D();
        pivot.rotation.x = def.inc;
        bgScene.add(pivot);

        // Planet body
        const pGeo = new THREE.SphereGeometry(def.r, 24, 24);
        const pMat = new THREE.MeshStandardMaterial({
          color: def.color,
          emissive: def.emissive,
          emissiveIntensity: 0.6,
          roughness: 0.7,
          metalness: 0.1
        });
        const planet = new THREE.Mesh(pGeo, pMat);
        planet.position.x = def.orbitR;
        pivot.add(planet);

        // Orbit ring (visible path)
        const oRingGeo = new THREE.TorusGeometry(def.orbitR, 0.6, 8, 256);
        const oRingMat = new THREE.MeshBasicMaterial({
          color: 0xffffff, transparent: true, opacity: 0.06,
          blending: THREE.AdditiveBlending
        });
        const oRing = new THREE.Mesh(oRingGeo, oRingMat);
        oRing.rotation.x = Math.PI / 2;
        bgScene.add(oRing);

        // Planetary rings (Saturn / Jupiter)
        if (def.hasRing) {
          const ringInner = def.bigRing ? def.r * 1.4 : def.r * 1.3;
          const ringOuter = def.bigRing ? def.r * 2.8 : def.r * 1.8;
          const rGeo = new THREE.RingGeometry(ringInner, ringOuter, 64);
          const rMat = new THREE.MeshBasicMaterial({
            color: def.bigRing ? 0xddcc88 : 0xaaaacc,
            transparent: true, opacity: 0.55, side: THREE.DoubleSide,
            blending: THREE.AdditiveBlending
          });
          const ring = new THREE.Mesh(rGeo, rMat);
          ring.rotation.x = def.bigRing ? Math.PI / 2.2 : Math.PI / 2.5;
          planet.add(ring);
        }

        // Moon
        if (def.hasMoon) {
          const moonPivot = new THREE.Object3D();
          planet.add(moonPivot);
          const mGeo = new THREE.SphereGeometry(8, 12, 12);
          const mMat = new THREE.MeshStandardMaterial({ color: 0xcccccc, emissive: 0x222222, emissiveIntensity: 0.4, roughness: 0.9 });
          const moon = new THREE.Mesh(mGeo, mMat);
          moon.position.x = def.r * 2.5;
          moonPivot.add(moon);
          orbitals.push({ mesh: moonPivot, type: 'moon', speed: 4.0 });
        }

        orbitals.push({ mesh: pivot, type: 'planet', speed: def.speed, angle: Math.random() * Math.PI * 2 });
        pivot.rotation.y = Math.random() * Math.PI * 2;
      });

      // â”€â”€â”€ STAR (Sun equivalent) â”€â”€â”€
      const starGeo = new THREE.SphereGeometry(65, 48, 48);
      const starMat = new THREE.MeshBasicMaterial({ color: 0xfffade });
      bgScene.add(new THREE.Mesh(starGeo, starMat));

      // Sun corona glow
      [85, 105, 130].forEach((r, i) => {
        const colors = [0xfffade, 0xffaa00, 0xff6600];
        const opacities = [0.4, 0.15, 0.06];
        const sg = new THREE.SphereGeometry(r, 32, 32);
        const sm = new THREE.MeshBasicMaterial({ color: colors[i], transparent: true, opacity: opacities[i], blending: THREE.AdditiveBlending, side: THREE.BackSide });
        bgScene.add(new THREE.Mesh(sg, sm));
      });

      // â”€â”€â”€ Point light from sun â”€â”€â”€
      const sunLight = new THREE.PointLight(0xfff5cc, 2.5, 3000);
      bgScene.add(sunLight);
      const ambLight = new THREE.AmbientLight(0x111133, 0.8);
      bgScene.add(ambLight);

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // D) ASTEROID BELT (3,000 chunks between Mars & Jupiter)
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      const astCount = 3000;
      const astPos = new Float32Array(astCount * 3);
      const astSizes = new Float32Array(astCount);

      for (let i = 0; i < astCount; i++) {
        const r = 830 + Math.random() * 100;
        const a = Math.random() * Math.PI * 2;
        const h = (Math.random() - 0.5) * 40;
        astPos[i*3]   = Math.cos(a) * r;
        astPos[i*3+1] = h;
        astPos[i*3+2] = Math.sin(a) * r;
        astSizes[i] = 1 + Math.random() * 3;
      }

      const astGeo = new THREE.BufferGeometry();
      astGeo.setAttribute('position', new THREE.BufferAttribute(astPos, 3));
      astGeo.setAttribute('size', new THREE.BufferAttribute(astSizes, 1));

      const astMat = new THREE.ShaderMaterial({
        uniforms: { time: { value: 0 } },
        vertexShader: `
          attribute float size;
          uniform float time;
          void main() {
            float a = atan(position.z, position.x) + time * 0.05;
            float r = length(position.xz);
            vec3 pos = vec3(cos(a)*r, position.y + sin(time * 0.3 + r) * 3.0, sin(a)*r);
            vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
            gl_PointSize = size * (800.0 / -mvPosition.z);
            gl_Position = projectionMatrix * mvPosition;
          }
        `,
        fragmentShader: `
          void main() {
            vec2 xy = gl_PointCoord - 0.5;
            if (length(xy) > 0.5) discard;
            gl_FragColor = vec4(0.7, 0.65, 0.6, 0.6);
          }
        `,
        transparent: true, depthWrite: false
      });
      const astMesh = new THREE.Points(astGeo, astMat);
      bgScene.add(astMesh);
      orbitals.push({ mesh: astMesh, type: 'asteroid' });

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // E) NEBULA CLOUDS (Volumetric Shader Particles)
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      const nebulaDefs = [
        { pos: [-2000, 400, -1500], color: [0.8, 0.2, 0.9], count: 2000, spread: 800 },
        { pos: [2200, -300, -800],  color: [0.1, 0.5, 1.0], count: 2000, spread: 700 },
        { pos: [500, 1200, -2500],  color: [1.0, 0.4, 0.1], count: 1500, spread: 600 },
        { pos: [-1800, -600, 1200], color: [0.2, 1.0, 0.6], count: 1500, spread: 650 },
      ];

      nebulaDefs.forEach(nDef => {
        const np = new Float32Array(nDef.count * 3);
        const nc = new Float32Array(nDef.count * 3);
        const ns = new Float32Array(nDef.count);

        for (let i = 0; i < nDef.count; i++) {
          np[i*3]   = nDef.pos[0] + (Math.random() - 0.5) * nDef.spread;
          np[i*3+1] = nDef.pos[1] + (Math.random() - 0.5) * nDef.spread * 0.6;
          np[i*3+2] = nDef.pos[2] + (Math.random() - 0.5) * nDef.spread;
          nc[i*3]   = nDef.color[0] * (0.6 + Math.random() * 0.4);
          nc[i*3+1] = nDef.color[1] * (0.6 + Math.random() * 0.4);
          nc[i*3+2] = nDef.color[2] * (0.6 + Math.random() * 0.4);
          ns[i] = 3 + Math.random() * 8;
        }

        const nGeo = new THREE.BufferGeometry();
        nGeo.setAttribute('position', new THREE.BufferAttribute(np, 3));
        nGeo.setAttribute('color', new THREE.BufferAttribute(nc, 3));
        nGeo.setAttribute('size', new THREE.BufferAttribute(ns, 1));

        const nMat = new THREE.ShaderMaterial({
          uniforms: { time: { value: 0 } },
          vertexShader: `
            attribute float size;
            attribute vec3 color;
            varying vec3 vColor;
            varying float vAlpha;
            uniform float time;
            void main() {
              vColor = color;
              float wobble = sin(time * 0.2 + position.x * 0.01) * 20.0;
              vec3 pos = position + vec3(0.0, wobble, 0.0);
              vAlpha = 0.15 + 0.1 * sin(time * 0.3 + position.z * 0.01);
              vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
              gl_PointSize = size * (1200.0 / -mvPos.z);
              gl_Position = projectionMatrix * mvPos;
            }
          `,
          fragmentShader: `
            varying vec3 vColor;
            varying float vAlpha;
            void main() {
              vec2 xy = gl_PointCoord - 0.5;
              float r = length(xy);
              if (r > 0.5) discard;
              float a = (1.0 - r*2.0) * vAlpha;
              gl_FragColor = vec4(vColor, a);
            }
          `,
          transparent: true, blending: THREE.AdditiveBlending,
          depthWrite: false, vertexColors: true
        });

        const nMesh = new THREE.Points(nGeo, nMat);
        bgScene.add(nMesh);
        orbitals.push({ mesh: nMesh, type: 'nebula' });
      });

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // F) BACKGROUND STARFIELD (60,000 stars)
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      const starCount = 60000;
      const sfPos = new Float32Array(starCount * 3);
      const sfCol = new Float32Array(starCount * 3);
      const sfSizes = new Float32Array(starCount);

      const starColorPalette = [
        [0.6, 0.7, 1.0], [1.0, 0.9, 0.8], [1.0, 0.7, 0.5],
        [0.7, 0.85, 1.0], [1.0, 1.0, 1.0], [0.9, 0.5, 0.3]
      ];

      for (let i = 0; i < starCount; i++) {
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        const r = 5000 + Math.random() * 40000;
        sfPos[i*3]   = r * Math.sin(phi) * Math.cos(theta);
        sfPos[i*3+1] = r * Math.sin(phi) * Math.sin(theta);
        sfPos[i*3+2] = r * Math.cos(phi);
        const c = starColorPalette[Math.floor(Math.random() * starColorPalette.length)];
        sfCol[i*3] = c[0]; sfCol[i*3+1] = c[1]; sfCol[i*3+2] = c[2];
        sfSizes[i] = 0.4 + Math.random() * (Math.random() < 0.02 ? 6 : 1.8);
      }

      const sfGeo = new THREE.BufferGeometry();
      sfGeo.setAttribute('position', new THREE.BufferAttribute(sfPos, 3));
      sfGeo.setAttribute('color', new THREE.BufferAttribute(sfCol, 3));
      sfGeo.setAttribute('size', new THREE.BufferAttribute(sfSizes, 1));

      const sfMat = new THREE.ShaderMaterial({
        uniforms: { time: { value: 0 } },
        vertexShader: `
          attribute float size;
          attribute vec3 color;
          varying vec3 vColor;
          uniform float time;
          varying float vTwinkle;
          void main() {
            vColor = color;
            vTwinkle = 0.7 + 0.3 * sin(time * 2.0 + position.x * 0.001 + position.y * 0.001);
            vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = size * (2000.0 / -mvPos.z) * vTwinkle;
            gl_Position = projectionMatrix * mvPos;
          }
        `,
        fragmentShader: `
          varying vec3 vColor;
          varying float vTwinkle;
          void main() {
            vec2 xy = gl_PointCoord - 0.5;
            float r = length(xy);
            if (r > 0.5) discard;
            float a = exp(-r*r * 10.0) * vTwinkle;
            gl_FragColor = vec4(vColor, a);
          }
        `,
        transparent: true, blending: THREE.AdditiveBlending,
        depthWrite: false, vertexColors: true
      });
      bgScene.add(new THREE.Points(sfGeo, sfMat));
      orbitals.push({ mesh: new THREE.Points(sfGeo, sfMat), type: 'starfield' });

      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      // G) COMETS / SHOOTING STARS
      // â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      for (let c = 0; c < 8; c++) {
        const cometGeo = new THREE.BufferGeometry();
        const trailLen = 60;
        const cPos = new Float32Array(trailLen * 3);
        const cSizes = new Float32Array(trailLen);
        const cColors = new Float32Array(trailLen * 3);

        for (let t = 0; t < trailLen; t++) {
          cPos[t*3] = 0; cPos[t*3+1] = 0; cPos[t*3+2] = 0;
          cSizes[t] = Math.max(0.5, (trailLen - t) / trailLen * 4);
          const fade = (trailLen - t) / trailLen;
          cColors[t*3] = 1.0; cColors[t*3+1] = 0.9 * fade; cColors[t*3+2] = fade;
        }

        cometGeo.setAttribute('position', new THREE.BufferAttribute(cPos, 3));
        cometGeo.setAttribute('size', new THREE.BufferAttribute(cSizes, 1));
        cometGeo.setAttribute('color', new THREE.BufferAttribute(cColors, 3));

        const cMat = new THREE.ShaderMaterial({
          uniforms: { time: { value: 0 } },
          vertexShader: `
            attribute float size;
            attribute vec3 color;
            varying vec3 vColor;
            void main() {
              vColor = color;
              vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
              gl_PointSize = size * (1000.0 / -mvPos.z);
              gl_Position = projectionMatrix * mvPos;
            }
          `,
          fragmentShader: `
            varying vec3 vColor;
            void main() {
              vec2 xy = gl_PointCoord - 0.5;
              if (length(xy) > 0.5) discard;
              float a = exp(-length(xy)*length(xy)*15.0);
              gl_FragColor = vec4(vColor, a * 0.8);
            }
          `,
          transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, vertexColors: true
        });

        const cometMesh = new THREE.Points(cometGeo, cMat);
        bgScene.add(cometMesh);
        comets.push({
          mesh: cometMesh,
          origin: new THREE.Vector3(
            (Math.random() - 0.5) * 4000,
            (Math.random() - 0.5) * 2000,
            (Math.random() - 0.5) * 4000
          ),
          velocity: new THREE.Vector3(
            (Math.random() - 0.5) * 15,
            (Math.random() - 0.5) * 8,
            (Math.random() - 0.5) * 15
          ),
          positions: Array.from({ length: trailLen }, () => new THREE.Vector3()),
          head: new THREE.Vector3(),
          progress: Math.random() * 100,
          period: 80 + Math.random() * 100
        });
      }

      // â”€â”€â”€ RESIZE â”€â”€â”€
      window.addEventListener('resize', () => {
        const w = window.innerWidth, h = window.innerHeight;
        bgCamera.aspect = w / h;
        bgCamera.updateProjectionMatrix();
        bgRenderer.setSize(w, h);
        if (bgComposer) bgComposer.setSize(w, h);
      });

      document.addEventListener('mousemove', e => {
        bgMouseX = (e.clientX - window.innerWidth / 2) * 0.3;
        bgMouseY = (e.clientY - window.innerHeight / 2) * 0.3;
      });
    }

    function animateBackgroundThree() {
      if (!bgCamera || !bgRenderer || !bgScene || !bgClock) return;
      requestAnimationFrame(animateBackgroundThree);

      const time = bgClock.getElapsedTime();
      const scrollY = window.__lenisScrollY || window.scrollY || 0;

      // â”€â”€â”€ UPDATE SHADERS â”€â”€â”€
      orbitals.forEach(o => {
        const mat = o.mesh.material;
        if (mat && mat.uniforms && mat.uniforms.time) {
          mat.uniforms.time.value = time;
        }

        // Animate planet orbits
        if (o.type === 'planet') {
          o.mesh.rotation.y += 0.0003 * o.speed;
        }
        if (o.type === 'moon') {
          o.mesh.rotation.y += 0.012 * o.speed;
        }
      });

      // â”€â”€â”€ ANIMATE COMETS â”€â”€â”€
      comets.forEach(comet => {
        comet.progress += 0.6;
        if (comet.progress > comet.period) {
          comet.progress = 0;
          comet.origin.set(
            (Math.random() - 0.5) * 4000,
            (Math.random() - 0.5) * 2000,
            (Math.random() - 0.5) * 4000
          );
          comet.velocity.set(
            (Math.random() - 0.5) * 18,
            (Math.random() - 0.5) * 8,
            (Math.random() - 0.5) * 18
          ).normalize().multiplyScalar(14 + Math.random() * 8);
        }

        // Update trail head
        const t = comet.progress / comet.period;
        comet.head.copy(comet.origin).addScaledVector(comet.velocity, comet.progress);

        // Shift trail
        comet.positions.unshift(comet.head.clone());
        if (comet.positions.length > 60) comet.positions.pop();

        // Update buffer
        const pos = comet.mesh.geometry.attributes.position;
        for (let i = 0; i < comet.positions.length; i++) {
          const p = comet.positions[i];
          pos.setXYZ(i, p.x, p.y, p.z);
        }
        pos.needsUpdate = true;
      });

      // â”€â”€â”€ GALAXY SLOW ROTATION â”€â”€â”€
      bgScene.rotation.y = Math.sin(time * 0.01) * 0.04;
      bgScene.rotation.z = Math.cos(time * 0.008) * 0.015;

      // â”€â”€â”€ CINEMATIC CAMERA â”€â”€â”€
      const targetX = bgMouseX * 1.2;
      const targetY = 1200 - bgMouseY * 1.2;
      const targetZ = 3200 - Math.min(scrollY * 0.25, 2200);
      bgCamera.position.x += (targetX - bgCamera.position.x) * 0.025;
      bgCamera.position.y += (targetY - bgCamera.position.y) * 0.025;
      bgCamera.position.z += (targetZ - bgCamera.position.z) * 0.04;
      bgCamera.lookAt(0, 0, 0);

      if (bgComposer) bgComposer.render();
      else bgRenderer.render(bgScene, bgCamera);
    }


    // ==========================================
    // 2. ASCII TORUS KNOT (HERO)
    // ==========================================
    let heroScene, heroCamera, heroRenderer, heroEffect, heroMesh;
    let hMouseX = 0, hMouseY = 0, hTargetX = 0, hTargetY = 0;

    
    function initHeroThree() {
      const container = document.getElementById('three-bg-container');
      if (!container) return;
      container.innerHTML = '';

      const width = container.clientWidth;
      const height = container.clientHeight;

      heroScene = new THREE.Scene();
      // Transparent background so the card gradient shows through
      heroScene.background = null;

      heroCamera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
      heroCamera.position.z = 12; // Bring it closer to fit the card

      heroRenderer = new THREE.WebGLRenderer({ alpha: true, antialias: false });
      heroRenderer.setSize(width, height);
      heroRenderer.setClearColor(0x000000, 0);

      if (typeof THREE.AsciiEffect !== 'undefined') {
        heroEffect = new THREE.AsciiEffect(heroRenderer, ' .:-+*=%@#', { invert: true, color: false, resolution: 0.2 });
        heroEffect.setSize(width, height);
        heroEffect.domElement.style.color = '#06b6d4'; // Cyan color
        heroEffect.domElement.style.backgroundColor = 'transparent';
        heroEffect.domElement.style.fontFamily = '"Fira Code", monospace';
        heroEffect.domElement.style.lineHeight = '1em';
        container.appendChild(heroEffect.domElement);
      } else {
        container.appendChild(heroRenderer.domElement);
        heroEffect = heroRenderer;
      }

      const ambientLight = new THREE.AmbientLight(0xffffff, 0.3);
      heroScene.add(ambientLight);

      const pointLight1 = new THREE.PointLight(0x06b6d4, 1.5);
      pointLight1.position.set(10, 10, 10);
      heroScene.add(pointLight1);
      
      const pointLight2 = new THREE.PointLight(0x10b981, 1);
      pointLight2.position.set(-10, -10, -10);
      heroScene.add(pointLight2);

      const geometry = new THREE.TorusKnotGeometry(3, 0.8, 100, 16);
      const material = new THREE.MeshStandardMaterial({ 
        color: 0xffffff,
        roughness: 0.3,
        metalness: 0.9
      });
      
      heroMesh = new THREE.Mesh(geometry, material);
      heroScene.add(heroMesh);

      const handleResize = () => {
        if (!container) return;
        const w = container.clientWidth;
        const h = container.clientHeight;
        heroCamera.aspect = w / h;
        heroCamera.updateProjectionMatrix();
        if (heroEffect) heroEffect.setSize(w, h);
        else heroRenderer.setSize(w, h);
      };
      window.addEventListener('resize', handleResize);

      // Track mouse within the card for interactive rotation
      container.addEventListener('mousemove', (e) => {
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        hTargetX = (x / rect.width) * 2 - 1;
        hTargetY = -(y / rect.height) * 2 + 1;
      });

      container.addEventListener('mouseleave', () => {
        hTargetX = 0;
        hTargetY = 0;
      });
      
      if (container.style) {
        container.style.mixBlendMode = 'screen';
      }
    }
function animateHeroThree(time = 0) {
      if (!heroCamera || !heroRenderer || !heroScene) return;
      requestAnimationFrame(animateHeroThree);

      // Smooth inertia mouse tracking
      hMouseX += (hTargetX - hMouseX) * 0.05;
      hMouseY += (hTargetY - hMouseY) * 0.05;

      // Rotate the ASCII Torus
      if (heroMesh) {
        heroMesh.rotation.x = time * 0.0005 + hMouseY * 0.5;
        heroMesh.rotation.y = time * 0.001 + hMouseX * 0.5;
      }

      if (heroEffect) {
        heroEffect.render(heroScene, heroCamera);
      } else {
        heroRenderer.render(heroScene, heroCamera);
      }
    }

    /* â”€â”€â”€ INTERACTIVE 3D PARALLAX TILT â”€â”€â”€ */
    function init3DTilt() {
      const cards = document.querySelectorAll('.skill-card, .work-card, .certificate-card, .project-card, .avatar-container, .visual-code-box');
      
      cards.forEach(card => {
        if (card.dataset.tiltInitialized) return;
        card.dataset.tiltInitialized = 'true';

        const parent = card.parentElement;
        if (parent) {
          parent.style.perspective = '1200px';
        }
        
        card.style.transformStyle = 'preserve-3d';
        card.style.willChange = 'transform';
        
        let glare = card.querySelector('.card-glare');
        if (!glare) {
          glare = document.createElement('div');
          glare.className = 'card-glare';
          glare.style.position = 'absolute';
          glare.style.inset = '0';
          glare.style.pointerEvents = 'none';
          glare.style.opacity = '0';
          glare.style.transition = 'opacity 0.3s ease';
          glare.style.zIndex = '10';
          glare.style.mixBlendMode = 'overlay';
          glare.style.borderRadius = 'inherit';
          card.appendChild(glare);
        }

        let rect = card.getBoundingClientRect();
        let targetX = 0;
        let targetY = 0;
        let currentX = 0;
        let currentY = 0;
        let isHovered = false;
        let animFrameId = null;

        function updateCardPosition() {
          if (!isHovered) {
            currentX += (0 - currentX) * 0.1;
            currentY += (0 - currentY) * 0.1;
            
            let glareOpacity = parseFloat(glare.style.opacity) || 0;
            glareOpacity += (0 - glareOpacity) * 0.1;
            glare.style.opacity = glareOpacity;
            
            if (Math.abs(currentX) < 0.01 && Math.abs(currentY) < 0.01) {
              card.style.transform = 'rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
              card.style.setProperty('--tilt-x', '0');
              card.style.setProperty('--tilt-y', '0');
              glare.style.opacity = '0';
              animFrameId = null;
              return;
            }
          } else {
            currentX += (targetX - currentX) * 0.12;
            currentY += (targetY - currentY) * 0.12;
            glare.style.opacity = '1';
          }

          card.style.transform = `rotateX(${currentX}deg) rotateY(${currentY}deg) scale3d(1.02, 1.02, 1.02)`;
          card.style.setProperty('--tilt-x', currentX);
          card.style.setProperty('--tilt-y', currentY);
          animFrameId = requestAnimationFrame(updateCardPosition);
        }

        card.addEventListener('mouseenter', () => {
          isHovered = true;
          playTick();
          rect = card.getBoundingClientRect();
          if (!animFrameId) {
            animFrameId = requestAnimationFrame(updateCardPosition);
          }
        });

        card.addEventListener('mousemove', (e) => {
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const w = rect.width;
          const h = rect.height;
          
          targetY = ((x / w) - 0.5) * 16; 
          targetX = (0.5 - (y / h)) * 16;
          
          const glareX = (x / w) * 100;
          const glareY = (y / h) * 100;
          glare.style.background = `radial-gradient(circle at ${glareX}% ${glareY}%, rgba(255, 255, 255, 0.15) 0%, transparent 60%)`;

          // Dynamic Vercel Card Border Glow coordinates
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
        
        card.addEventListener('mouseleave', () => {
          isHovered = false;
        });
      });
    }

    /* â”€â”€â”€ TACTILE ELASTIC MAGNETIC HOVER BUTTONS â”€â”€â”€ */
    function initMagneticButtons() {
      // Targets CTA buttons, theme/audio togglers, and navigation links
      const targets = document.querySelectorAll('#btn-hero-projects, #btn-hero-contact, #btn-theme, #btn-audio, .nav-link-item, #btn-hamburger');
      
      targets.forEach(el => {
        el.addEventListener('mousemove', (e) => {
          const rect = el.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          
          // Pull the element towards the mouse by 35% of the distance
          el.style.transform = `translate(${x * 0.35}px, ${y * 0.35}px) scale(1.05)`;
          el.style.transition = 'none';
          el.style.boxShadow = '0 10px 30px rgba(59, 130, 246, 0.2)';
        });
        
        el.addEventListener('mouseenter', () => {
          playTick();
        });
        
        el.addEventListener('click', () => {
          playPulse();
        });
        
        el.addEventListener('mouseleave', () => {
          // Snap back smoothly
          el.style.transform = 'translate(0px, 0px) scale(1)';
          el.style.transition = 'transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease';
          el.style.boxShadow = '';
        });
      });

      // Bind link text scramble on hover for all nav link items
      document.querySelectorAll('.nav-link-item').forEach(el => {
        el.addEventListener('mouseenter', () => {
          scrambleText(el, el.innerText);
        });
      });
    }

    /* â”€â”€â”€ INTERACTIVE PARTICLE CURSOR TRAIL â”€â”€â”€ */
    function initCursorTrail() {
      if (window.innerWidth < 768) return; // Disable on mobile devices for battery saving
      
      const canvas = document.getElementById('cursor-trail-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let trailParticles = [];
      const codeSymbols = ["{", "}", "<", ">", "++", "[]", "const", "0", "1", "=>", "()", ";"];
      let mouse = { x: null, y: null };
      
      function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      window.addEventListener('mousemove', (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;

        // Throttled spawning (cap max active particles)
        if (trailParticles.length >= 60) return;

        // Spawn glowing code particles on mouse movements
        for (let i = 0; i < 1; i++) {
          trailParticles.push({
            x: e.clientX,
            y: e.clientY,
            text: codeSymbols[Math.floor(Math.random() * codeSymbols.length)],
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5 - 0.4, // float upwards
            size: Math.floor(Math.random() * 5) + 10, // Font size 10px to 15px
            color: Math.random() > 0.5 ? '#3b82f6' : '#10b981', // electric blue or emerald green
            alpha: 1.0,
            decay: Math.random() * 0.015 + 0.012,
            angle: Math.random() * Math.PI * 2,
            angularVelocity: (Math.random() - 0.5) * 0.06
          });
        }
      });

      window.addEventListener('click', (e) => {
        // Spawn ring of exploding neon particles
        const burstSymbols = ["âœ¦", "âœ¨", "0", "1", "<>", "{}", "*/", "++", ";", "{", "}", "[", "]", "()"];
        const count = Math.min(12, 60 - trailParticles.length);
        for (let i = 0; i < count; i++) {
          const speed = Math.random() * 5 + 3;
          const angle = Math.random() * Math.PI * 2;
          trailParticles.push({
            x: e.clientX,
            y: e.clientY,
            text: burstSymbols[Math.floor(Math.random() * burstSymbols.length)],
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            size: Math.floor(Math.random() * 6) + 12,
            color: Math.random() > 0.5 ? '#3b82f6' : '#10b981',
            alpha: 1.0,
            decay: Math.random() * 0.02 + 0.015,
            angle: Math.random() * Math.PI * 2,
            angularVelocity: (Math.random() - 0.5) * 0.1
          });
        }
      });

      window.addEventListener('mouseout', () => {
        mouse.x = null;
        mouse.y = null;
      });

      function animate() {
        requestAnimationFrame(animate);
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // 1. Draw connecting web lines (Constellation Effect)
        for (let i = 0; i < trailParticles.length; i++) {
          const p1 = trailParticles[i];
          
          // Connection to mouse cursor
          if (mouse.x !== null && mouse.y !== null) {
            const dx = p1.x - mouse.x;
            const dy = p1.y - mouse.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < 100) {
              ctx.beginPath();
              ctx.moveTo(p1.x, p1.y);
              ctx.lineTo(mouse.x, mouse.y);
              ctx.strokeStyle = p1.color;
              ctx.globalAlpha = (1 - dist / 100) * p1.alpha * 0.28;
              ctx.lineWidth = 0.8;
              ctx.stroke();
            }
          }

          // Connections between nearby particles
          for (let j = i + 1; j < trailParticles.length; j++) {
            const p2 = trailParticles[j];
            const dx = p1.x - p2.x;
            const dy = p1.y - p2.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < 80) {
              ctx.beginPath();
              ctx.moveTo(p1.x, p1.y);
              ctx.lineTo(p2.x, p2.y);
              ctx.strokeStyle = p1.color;
              ctx.globalAlpha = (1 - dist / 80) * Math.min(p1.alpha, p2.alpha) * 0.22;
              ctx.lineWidth = 0.6;
              ctx.stroke();
            }
          }
        }
        
        // 2. Update and draw code character particles
        for (let i = trailParticles.length - 1; i >= 0; i--) {
          const p = trailParticles[i];
          p.x += p.vx;
          p.y += p.vy;
          p.angle += p.angularVelocity;
          p.alpha -= p.decay;
          
          if (p.alpha <= 0) {
            trailParticles.splice(i, 1);
            continue;
          }
          
          ctx.save();
          ctx.globalAlpha = p.alpha;
          ctx.fillStyle = p.color;
          ctx.shadowBlur = 6;
          ctx.shadowColor = p.color;
          ctx.font = `bold ${p.size}px Fira Code, monospace`;
          ctx.translate(p.x, p.y);
          ctx.rotate(p.angle);
          ctx.fillText(p.text, -p.size/2, p.size/2);
          ctx.restore();
        }
      }
      animate();
    }

    /* â”€â”€â”€ SCROLL PROGRESS AND BACK TO TOP HUD â”€â”€â”€ */
    function initScrollProgressAndHUD() {
      window.addEventListener('scroll', () => {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const percentage = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        
        const progressBar = document.getElementById('scroll-progress');
        if (progressBar) {
          progressBar.style.width = `${percentage}%`;
          
          // Shifting bar glow color dynamically matching the active section
          const colors = sectionColors[activeSectionName] || sectionColors.home;
          progressBar.style.background = `linear-gradient(90deg, ${colors.c1}, ${colors.c2})`;
          progressBar.style.boxShadow = `0 0 10px ${colors.c1}, 0 0 5px ${colors.c2}`;
        }

        const b2t = document.getElementById('back-to-top-hud');
        if (b2t) {
          if (window.scrollY > 300) {
            b2t.classList.add('active');
          } else {
            b2t.classList.remove('active');
          }
          
          const circle = b2t.querySelector('.progress');
          if (circle) {
            const offset = 138 - (percentage / 100) * 138;
            circle.style.strokeDashoffset = offset;
          }
        }
      });
    }

    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    }

    /* â”€â”€â”€ INTERACTIVE TERMINAL HUD CONSOLE â”€â”€â”€ */
    let terminalHUDInitialized = false;
    let terminalBooted = false;

    function toggleTerminalHUD() {
      const hud = document.getElementById('terminal-hud');
      if (!hud) return;
      
      const isActive = hud.classList.contains('active');
      if (isActive) {
        hud.classList.remove('active');
      } else {
        hud.classList.add('active');
        const input = document.getElementById('terminal-input');
        if (input) setTimeout(() => input.focus(), 150);
        
        if (!terminalBooted) {
          bootTerminal();
        }
      }
    }

    function bootTerminal() {
      terminalBooted = true;
      const logs = [
        "Initializing Mercy-OS v3.0.0...",
        "Loading Modules: WebAudio, ParticleEmitter, ThreeJS...",
        "Fetching credentials for github.com/Mercy222222...",
        "System Status: ONLINE. Ready to execute commands."
      ];
      
      let delay = 300;
      logs.forEach((log, idx) => {
        setTimeout(() => {
          appendTerminalLog(log, 'system');
          playKeyboardClick();
          if (idx === logs.length - 1) {
            appendTerminalLog("Type 'help' to see list of commands.", 'info');
          }
        }, delay);
        delay += 600;
      });
    }

    function appendTerminalLog(text, type = 'info') {
      const container = document.getElementById('terminal-logs');
      if (!container) return;
      
      const line = document.createElement('div');
      line.className = 'leading-relaxed select-text';
      
      if (type === 'system') {
        line.innerHTML = `<span class="text-zinc-400 dark:text-zinc-500">[SYS]</span> ${text}`;
      } else if (type === 'user') {
        line.innerHTML = `<span class="text-cyan-400 dark:text-green-500 font-bold">$</span> <span class="text-zinc-900 dark:text-white">${text}</span>`;
      } else if (type === 'error') {
        line.innerHTML = `<span class="text-red-500 font-bold">[ERR]</span> ${text}`;
      } else if (type === 'success') {
        line.innerHTML = `<span class="text-cyan-400 font-bold">[OK]</span> ${text}`;
      } else {
        line.innerHTML = `<span class="text-zinc-400 dark:text-zinc-500">[INFO]</span> ${text}`;
      }
      
      container.appendChild(line);
      container.scrollTop = container.scrollHeight;
    }

    function initTerminalHUD() {
      if (terminalHUDInitialized) return;
      terminalHUDInitialized = true;
      
      const input = document.getElementById('terminal-input');
      if (!input) return;
      
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const rawVal = input.value;
          const cmd = rawVal.trim().toLowerCase();
          input.value = '';
          
          if (!cmd) return;
          
          playKeyboardClick();
          appendTerminalLog(rawVal, 'user');
          
          setTimeout(() => {
            interpretTerminalCommand(cmd);
          }, 150);
        } else {
          playKeyboardClick();
        }
      });

      const termBody = document.getElementById('terminal-body');
      if (termBody) {
        termBody.addEventListener('click', () => {
          input.focus();
        });
      }
    }

    function interpretTerminalCommand(cmd) {
      if (cmd === 'help') {
        appendTerminalLog("Available commands:", 'info');
        appendTerminalLog("  about    - Summary about Vo Huu Tri", 'info');
        appendTerminalLog("  skills   - List of technical capabilities", 'info');
        appendTerminalLog("  projects - Dynamic list of core web products", 'info');
        appendTerminalLog("  clear    - Clear console display", 'info');
        appendTerminalLog("  matrix   - Trigger retro code rain matrix", 'info');
        appendTerminalLog("  secret   - Trigger a secret particle event", 'info');
      } else if (cmd === 'clear') {
        const container = document.getElementById('terminal-logs');
        if (container) container.innerHTML = '';
      } else if (cmd === 'about') {
        appendTerminalLog("Mercy-OS Profile:", 'success');
        appendTerminalLog("  Name: VÃµ Há»¯u TrÃ­", 'info');
        appendTerminalLog("  Role: Fullstack Web Developer", 'info');
        appendTerminalLog("  Origin: VÄ©nh Long, Vietnam", 'info');
        appendTerminalLog("  Specialty: PHP, MySQL, JS, SMM Automation", 'info');
      } else if (cmd === 'skills') {
        appendTerminalLog("Loaded Skill Matrix:", 'success');
        const skillList = YS.map(s => s.label).join(", ");
        appendTerminalLog(`  ${skillList}`, 'info');
      } else if (cmd === 'projects') {
        appendTerminalLog("Querying Active Projects:", 'success');
        appendTerminalLog("  - Vo Huu Tri SMM Panel (Automated interaction server)", 'info');
        appendTerminalLog("  - Vo Huu Tri Blogs (PSD sharing & system tips)", 'info');
      } else if (cmd === 'secret') {
        appendTerminalLog("Triggering secret protocol... BLAST OUT!", 'success');
        confetti({
          particleCount: 150,
          spread: 80,
          origin: { y: 0.6 }
        });
        playWelcomeChime();
      } else if (cmd === 'matrix') {
        appendTerminalLog("Entering matrix stream...", 'success');
        let count = 0;
        const interval = setInterval(() => {
          const binaryLine = Math.random().toString(2).substring(2, 18);
          appendTerminalLog(binaryLine, 'info');
          count++;
          if (count > 10) clearInterval(interval);
        }, 150);
      } else {
        appendTerminalLog(`Command not found: '${cmd}'. Type 'help' for commands.`, 'error');
      }
    }

    function playKeyboardClick() {
      if (isAudioMuted || !audioCtx) return;
      initAudio();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(100 + Math.random() * 800, audioCtx.currentTime);
      gain.gain.setValueAtTime(0.012, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.02);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.02);
    }
  </script>

  <!-- Floating Hacker Terminal HUD -->
  <div id="terminal-hud" class="border border-zinc-300 dark: bg-white/95 dark:bg-black/95 backdrop-blur-md font-mono flex flex-col text-xs text-zinc-700 dark:text-green-400">
    <!-- Terminal Header -->
    <div class="h-9 bg-zinc-200 dark:securify-card border-b border-zinc-300 dark: flex justify-between items-center px-4 select-none">
          <div class="glare"></div>
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-red-500"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
        <span class="w-3 h-3 rounded-full bg-green-500"></span>
        <span class="ml-1 text-[10px] font-bold text-zinc-500 ">MERCY-OS // CONSOLE</span>
      </div>
      <button onclick="toggleTerminalHUD()" class="text-zinc-500 hover:text-red-500 transition-colors">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <!-- Terminal Body -->
    <div id="terminal-body" class="flex-1 overflow-y-auto p-4 space-y-2 flex flex-col justify-end">
      <div class="text-[10px] text-zinc-400 dark:text-zinc-500 mb-2">Type 'help' for a list of commands.</div>
      <div id="terminal-logs" class="space-y-1.5 overflow-y-auto max-h-[200px]"></div>
      <!-- Terminal Input Line -->
      <div class="flex items-center gap-1.5 border-t border-zinc-100 dark:border-zinc-900 pt-2">
        <span class="text-cyan-400 dark:text-green-500 font-bold">$</span>
        <input type="text" id="terminal-input" class="flex-1 bg-transparent border-none outline-none text-zinc-800 dark:text-green-400 font-mono caret-emerald-500 dark:caret-green-400" autocomplete="off" />
      </div>
    </div>
  </div>

  <!-- Terminal Open Button -->
  <div id="terminal-toggle-btn" onclick="toggleTerminalHUD()" title="Open Terminal Console">
    <i class="fas fa-terminal text-lg"></i>
  </div>

  <!-- Back to Top HUD -->
  <div id="back-to-top-hud" onclick="scrollToTop()" title="Back to Top">
    <svg viewBox="0 0 50 50">
      <circle class="track" cx="25" cy="25" r="22"></circle>
      <circle class="progress" cx="25" cy="25" r="22"></circle>
    </svg>
    <i class="fas fa-chevron-up text-sm"></i>
  </div>
  <script>

    /* --- SINGULARITY TIER GLOBAL SPOTLIGHT --- */
    window.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.securify-card').forEach(card => {
        const glare = document.createElement('div');
        glare.className = 'card-glare';
        card.appendChild(glare);
      });
      
      // Global Mouse Tracker for Spotlight (without tilt)
      document.addEventListener('mousemove', (e) => {
        document.querySelectorAll('.securify-card').forEach(card => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });
    });

  </script>

  <!-- GLOBAL 3D PLEXUS SCRIPT -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const canvas = document.getElementById('global-3d-bg');
      if (!canvas || typeof THREE === 'undefined') return;

      const scene = new THREE.Scene();
      scene.fog = new THREE.FogExp2(0x0b1121, 0.0015);

      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 2000);
      camera.position.z = 300;

      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(window.devicePixelRatio);
      renderer.setSize(window.innerWidth, window.innerHeight);

      // Unreal Bloom Setup
      let composer;
      if (typeof THREE.EffectComposer !== 'undefined') {
        const renderScene = new THREE.RenderPass(scene, camera);
        const bloomPass = new THREE.UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.5, 0.4, 0.85);
        bloomPass.threshold = 0;
        bloomPass.strength = 2.0; // Intense neon glow
        bloomPass.radius = 0.5;

        composer = new THREE.EffectComposer(renderer);
        composer.addPass(renderScene);
        composer.addPass(bloomPass);
      }

      // 1. Particles (Plexus)
      const particleCount = 250;
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(particleCount * 3);
      const velocities = [];
      const basePositions = [];

      for (let i = 0; i < particleCount; i++) {
        const x = (Math.random() - 0.5) * 1200;
        const y = (Math.random() - 0.5) * 1200;
        const z = (Math.random() - 0.5) * 800;
        positions[i * 3] = x;
        positions[i * 3 + 1] = y;
        positions[i * 3 + 2] = z;
        basePositions.push({ x, y, z });
        velocities.push({ x: 0, y: 0, z: 0 });
      }
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

      const pMaterial = new THREE.PointsMaterial({
        color: 0x06b6d4, size: 4, transparent: true, opacity: 0.9, blending: THREE.AdditiveBlending
      });
      const particles = new THREE.Points(geometry, pMaterial);
      scene.add(particles);

      const lineMaterial = new THREE.LineBasicMaterial({
        color: 0x10b981, transparent: true, opacity: 0.25, blending: THREE.AdditiveBlending
      });
      const lineGeometry = new THREE.BufferGeometry();
      const linesMesh = new THREE.LineSegments(lineGeometry, lineMaterial);
      scene.add(linesMesh);

      // 2. Floating Icosahedrons (Giant wireframe objects)
      const icoGroup = new THREE.Group();
      const icoGeo = new THREE.IcosahedronGeometry(80, 0);
      const icoMat = new THREE.MeshBasicMaterial({ color: 0x8b5cf6, wireframe: true, transparent: true, opacity: 0.15 });
      for (let i=0; i<5; i++) {
        const mesh = new THREE.Mesh(icoGeo, icoMat);
        mesh.position.set((Math.random() - 0.5) * 1500, (Math.random() - 0.5) * 1500, (Math.random() - 0.5) * 1000 - 300);
        mesh.rotation.set(Math.random()*Math.PI, Math.random()*Math.PI, 0);
        icoGroup.add(mesh);
      }
      scene.add(icoGroup);

      // Mouse & Raycaster for Repulsion
      let mouse = new THREE.Vector2();
      let targetCamera = { x: 0, y: 0 };
      const raycaster = new THREE.Raycaster();
      const plane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
      let pointOfIntersection = new THREE.Vector3();

      document.addEventListener('mousemove', (event) => {
        mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
        mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
        targetCamera.x = mouse.x * 100;
        targetCamera.y = mouse.y * 100;
      });

      let scrollY = 0;
      window.addEventListener('scroll', () => { scrollY = window.scrollY; });

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        if(composer) composer.setSize(window.innerWidth, window.innerHeight);
      });

      function animate() {
        requestAnimationFrame(animate);

        // Repulsion Physics
        raycaster.setFromCamera(mouse, camera);
        raycaster.ray.intersectPlane(plane, pointOfIntersection);

        const posAttribute = geometry.attributes.position;
        const array = posAttribute.array;
        let linePositions = [];

        for (let i = 0; i < particleCount; i++) {
          const i3 = i * 3;
          let px = array[i3], py = array[i3+1], pz = array[i3+2];
          let bx = basePositions[i].x, by = basePositions[i].y, bz = basePositions[i].z;

          // Push away from mouse intersection
          const dx = px - pointOfIntersection.x;
          const dy = py - pointOfIntersection.y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          const force = Math.max(0, 250 - dist) * 0.05;

          if (dist < 250) {
            velocities[i].x += (dx / dist) * force;
            velocities[i].y += (dy / dist) * force;
          }

          // Spring back to base position
          velocities[i].x += (bx - px) * 0.02;
          velocities[i].y += (by - py) * 0.02;
          velocities[i].z += (bz - pz) * 0.02;

          // Dampening
          velocities[i].x *= 0.9;
          velocities[i].y *= 0.9;
          velocities[i].z *= 0.9;

          array[i3] += velocities[i].x;
          array[i3+1] += velocities[i].y;
          array[i3+2] += velocities[i].z;

          // Lines
          for (let j = i + 1; j < particleCount; j++) {
            const j3 = j * 3;
            const dpx = array[i3] - array[j3];
            const dpy = array[i3 + 1] - array[j3 + 1];
            const dpz = array[i3 + 2] - array[j3 + 2];
            if (dpx*dpx + dpy*dpy + dpz*dpz < 20000) {
              linePositions.push(array[i3], array[i3 + 1], array[i3 + 2], array[j3], array[j3 + 1], array[j3 + 2]);
            }
          }
        }
        posAttribute.needsUpdate = true;
        lineGeometry.setAttribute('position', new THREE.Float32BufferAttribute(linePositions, 3));

        // Group Rotations
        particles.rotation.y += 0.0005;
        linesMesh.rotation.y = particles.rotation.y;
        
        icoGroup.children.forEach(mesh => {
          mesh.rotation.x += 0.001;
          mesh.rotation.y += 0.002;
        });
        icoGroup.rotation.y -= 0.0005;

        // Camera Smooth Movement
        camera.position.x += (targetCamera.x - camera.position.x) * 0.02;
        camera.position.y += (targetCamera.y - camera.position.y) * 0.02;
        camera.position.z = 300 - (scrollY * 0.08);
        camera.lookAt(scene.position);

        if (composer) composer.render();
        else renderer.render(scene, camera);
      }
      animate();
    });
  </script>

  <!-- GOD TIER ENGINE -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Initialize Lenis
      const lenis = new Lenis({
        duration: 1.5,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        gestureDirection: 'vertical',
        smooth: true,
        mouseMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Sync GSAP with Lenis
      if(typeof ScrollTrigger !== 'undefined') {
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time)=>{ lenis.raf(time * 1000) });
        gsap.ticker.lagSmoothing(0);
      }

      // Export Lenis scroll position for the Black Hole parallax
      lenis.on('scroll', ({ scroll }) => {
        window.__lenisScrollY = scroll;
      });
      


      // Terminal 3D Tilt
      const terminal = document.getElementById('terminal-hud');
      if (terminal) {
        const xToTerm = gsap.quickTo(terminal, "rotationY", {duration: 0.5, ease: "power3"});
        const yToTerm = gsap.quickTo(terminal, "rotationX", {duration: 0.5, ease: "power3"});
        
        terminal.addEventListener('mousemove', (e) => {
          const rect = terminal.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          xToTerm((e.clientX - cx) * 0.05);
          yToTerm(-(e.clientY - cy) * 0.05);
        });
        terminal.addEventListener('mouseleave', () => {
          xToTerm(0);
          yToTerm(0);
        });
      }

      
      // Add data-text to typing line for glitch
      const typingLines = document.querySelectorAll('#terminal-body p');
      typingLines.forEach(p => {
        p.setAttribute('data-text', p.innerText);
        p.classList.add('glitch-typing');
      });

      



      // --- OMNIVERSE GLOBAL 3D SPLIT TEXT ---
      const omniTitles = document.querySelectorAll('.omni-split');
      omniTitles.forEach(title => {
        const text = title.innerText;
        title.innerHTML = '';
        title.setAttribute('data-text', text); // For glitch
        const words = text.split(' ');
        words.forEach(word => {
          const span = document.createElement('span');
          span.innerHTML = word + '&nbsp;';
          span.style.display = 'inline-block';
          title.appendChild(span);
        });

        gsap.fromTo(title.querySelectorAll('span'), 
          { opacity: 0, rotationX: 90, rotationY: 45, z: 200, scale: 2, filter: 'blur(15px)' },
          {
            scrollTrigger: {
              trigger: title,
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            },
            opacity: 1, rotationX: 0, rotationY: 0, z: 0, scale: 1, filter: 'blur(0px)',
            stagger: 0.1, duration: 1.5, ease: "expo.out"
          }
        );
      });


      // 2. Custom Cursor
      const cursor = document.querySelector('.god-cursor');
      let mouseX = 0, mouseY = 0, cursorX = 0, cursorY = 0;
      
      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      // Smooth follow
      gsap.ticker.add(() => {
        cursorX += (mouseX - cursorX) * 0.2;
        cursorY += (mouseY - cursorY) * 0.2;
        cursor.style.transform = `translate(${cursorX}px, ${cursorY}px) translate(-50%, -50%)`;
      });

      // Hover Effects
      const interactiveEls = document.querySelectorAll('a, button, .securify-card, .magnetic');
      interactiveEls.forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('hovering'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('hovering'));
      });

      // 3. Magnetic Physics
      const magnetics = document.querySelectorAll('.nav-link, #btn-hero-projects, #btn-hero-contact, .pill-badge');
      magnetics.forEach(el => {
        el.classList.add('magnetic-wrap');
        const xTo = gsap.quickTo(el, "x", {duration: 1, ease: "elastic.out(1, 0.3)"});
        const yTo = gsap.quickTo(el, "y", {duration: 1, ease: "elastic.out(1, 0.3)"});

        el.addEventListener("mousemove", (e) => {
          const rect = el.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          xTo((e.clientX - cx) * 0.4);
          yTo((e.clientY - cy) * 0.4);
        });
        el.addEventListener("mouseleave", () => {
          xTo(0); yTo(0);
        });
      });
    });
  </script>

<!-- --- GSAP & 3D INTERACTION SCRIPT --- -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      gsap.registerPlugin(ScrollTrigger);

      // 1. Beyond Ultra Text Scrub (3D Flip & Blur)
      const splitText = document.getElementById('about-scrub');
      if (splitText) {
        const words = splitText.innerText.split(' ');
        splitText.innerHTML = '';
        words.forEach(word => {
          const span = document.createElement('span');
          span.innerHTML = word + '&nbsp;';
          span.style.display = 'inline-block'; // Required for transform
          splitText.appendChild(span);
        });

        gsap.fromTo('#about-scrub span', 
          { opacity: 0, rotationX: -90, z: -100, filter: 'blur(10px)', y: 20 },
          {
            scrollTrigger: {
              trigger: '#about-scrub',
              start: 'top 85%',
              end: 'bottom 40%',
              scrub: 1.5,
            },
            opacity: 1, rotationX: 0, z: 0, filter: 'blur(0px)', y: 0,
            stagger: 0.05, ease: 'back.out(1.7)'
          }
        );
      }

      // 2. Work Experience Pinned Scroll
      const workPinned = document.getElementById('work-pinned');
      const workScroll = document.getElementById('work-scroll');
      if (workPinned && workScroll && window.innerWidth >= 1024) {
        ScrollTrigger.create({
          trigger: '#workExp',
          start: 'top 20%',
          end: 'bottom bottom',
          pin: '#work-pinned',
          pinSpacing: false,
        });
      }

      // 3. Origami Fold-Out Reveals
      gsap.utils.toArray('.gs-reveal-up').forEach(elem => {
        gsap.fromTo(elem, 
          { y: 100, opacity: 0, rotationX: 30, scale: 0.9 }, 
          {
            scrollTrigger: { trigger: elem, start: 'top 90%', toggleActions: 'play none none reverse' },
            y: 0, opacity: 1, rotationX: 0, scale: 1,
            duration: 1.2, ease: 'elastic.out(1, 0.7)'
          }
        );
      });

      gsap.utils.toArray('.gs-reveal-right').forEach((elem, i) => {
        gsap.fromTo(elem, 
          { x: -100, opacity: 0, rotationY: -30, scale: 0.9 }, 
          {
            scrollTrigger: { trigger: elem, start: 'top 85%', toggleActions: 'play none none reverse' },
            x: 0, opacity: 1, rotationY: 0, scale: 1,
            duration: 1.2, ease: 'elastic.out(1, 0.7)', delay: i * 0.15
          }
        );
      });

      // 4. SINGULARITY TIER: Buttery Smooth GSAP Tilt & Glare
      const cards = document.querySelectorAll('.securify-card');
      cards.forEach(card => {
        const glare = card.querySelector('.card-glare');
        
        const xTo = gsap.quickTo(card, "rotationY", {duration: 0.6, ease: "power3.out"});
        const yTo = gsap.quickTo(card, "rotationX", {duration: 0.6, ease: "power3.out"});
        const scaleTo = gsap.quickTo(card, "scale", {duration: 0.6, ease: "power3.out"});
        const glareXTo = glare ? gsap.quickTo(glare, "xPercent", {duration: 0.4, ease: "power2.out"}) : null;
        const glareYTo = glare ? gsap.quickTo(glare, "yPercent", {duration: 0.4, ease: "power2.out"}) : null;

        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          
          // Smooth GSAP variables
          const tiltX = ((y - centerY) / centerY) * -8; 
          const tiltY = ((x - centerX) / centerX) * 8;
          
          // Apply GSAP animation instantly without jitter
          xTo(tiltY);
          yTo(tiltX);
          scaleTo(1.02);
          
          // Glare movement
          if (glare) {
            const percentageX = (x / rect.width) * 100 - 50;
            const percentageY = (y / rect.height) * 100 - 50;
            glareXTo(percentageX);
            glareYTo(percentageY);
          }
        });
        
        card.addEventListener('mouseleave', () => {
          xTo(0);
          yTo(0);
          scaleTo(1);
          if (glare) {
            glareXTo(0);
            glareYTo(0);
          }
        });
      });
    });
  </script>
</body>
</html>

