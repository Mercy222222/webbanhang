            <div class="text-[10px] italic text-slate-400 font-sans mb-2">${currentLanguage === 'vi' ? 'Chá»©ng nháº­n hoÃ n thÃ nh trao cho' : 'This is to certify that'}</div>
            <div class="text-xl font-bold text-slate-900 dark:text-white font-serif py-1 border-b border-dashed border-slate-300 dark:border-slate-700 max-w-xs mx-auto mb-3">VÃ• Há»®U TRÃ</div>
            
            <div class="text-[11px] text-slate-500 dark:text-slate-400 leading-relaxed font-sans max-w-sm mx-auto mb-5">
              ${currentLanguage === 'vi' ? 'Ä‘Ã£ hoÃ n thÃ nh xuáº¥t sáº¯c cÃ¡c yÃªu cáº§u há»c táº­p, kiá»ƒm tra cháº¥t lÆ°á»£ng cá»§a khÃ³a há»c chuyÃªn mÃ´n vÃ  Ä‘Æ°á»£c há»‡ thá»‘ng ghi nháº­n chÃ­nh thá»©c.' : 'has successfully fulfilled all academic requirements, tests, and assessments for this professional program.'}
            </div>
            
            <div class="grid grid-cols-2 gap-4 pt-3 border-t border-slate-200 dark:border-slate-800 text-left font-sans text-[10px]">
              <div>
                <span class="text-slate-400 block">${currentLanguage === 'vi' ? 'NgÃ y cáº¥p:' : 'Issue Date:'}</span>
                <strong class="text-slate-600 dark:text-slate-300">${date}</strong>
              </div>
              <div class="text-right">
                <span class="text-slate-400 block">${currentLanguage === 'vi' ? 'MÃ£ sá»‘ chá»©ng chá»‰:' : 'Credential ID:'}</span>
                <strong class="text-cyan-400 dark:text-blue-400 font-mono">${id_code}</strong>
              </div>
            </div>
            
            <div class="mt-4 text-[9px] text-slate-400 italic">
              ${currentLanguage === 'vi' ? '* Chá»©ng chá»‰ Ä‘Æ°á»£c mÃ£ hÃ³a xÃ¡c thá»±c Ä‘iá»‡n tá»­ trá»±c tuyáº¿n vÃ  báº£o máº­t.' : '* This credential is split-verified and securely registered in our system.'}
            </div>
          </div>
        `,
        background: currentTheme === 'dark' ? 'rgba(15, 23, 42, 0.98)' : '#ffffff',
        color: currentTheme === 'dark' ? '#f8fafc' : '#0f172a',
        showConfirmButton: true,
        confirmButtonText: currentLanguage === 'vi' ? 'XÃ¡c nháº­n ÄÃ³ng' : 'Close',
        confirmButtonColor: '#b45309', // gold/amber color
        width: '460px'
      });
