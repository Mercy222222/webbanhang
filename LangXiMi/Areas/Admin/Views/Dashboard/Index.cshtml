@model LangXiMi.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon orders"><i class="bi bi-receipt"></i></div>
            <div>
                <div class="stat-value">@Model.TotalOrders</div>
                <div class="stat-label">Tổng đơn hàng</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon pending"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="stat-value">@Model.PendingOrders</div>
                <div class="stat-label">Chờ xác nhận</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon products"><i class="bi bi-box-seam"></i></div>
            <div>
                <div class="stat-value">@Model.TotalProducts</div>
                <div class="stat-label">Sản phẩm đang bán</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon revenue"><i class="bi bi-cash-coin"></i></div>
            <div>
                <div class="stat-value">@Model.MonthRevenue.ToString("N0")₫</div>
                <div class="stat-label">Doanh thu tháng này</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Orders -->
    <div class="col-lg-8">
        <div class="admin-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Đơn hàng gần đây</h5>
                <a asp-action="Index" asp-controller="Order" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Khách hàng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày đặt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders)
                        {
                            var badgeClass = o.Status switch {
                                "Chờ xác nhận" => "badge-cho-xac-nhan",
                                "Đang làm" => "badge-dang-lam",
                                "Đang giao hàng" => "badge-dang-giao",
                                "Hoàn thành" => "badge-hoan-thanh",
                                "Đã hủy" => "badge-da-huy",
                                _ => ""
                            };
                            <tr>
                                <td><a asp-action="Details" asp-controller="Order" asp-route-id="@o.OrderId" class="fw-bold">#@o.OrderId</a></td>
                                <td>@o.Customer?.FullName</td>
                                <td class="fw-semibold">@o.TotalAmount.ToString("N0")₫</td>
                                <td><span class="badge-status @badgeClass">@o.Status</span></td>
                                <td class="text-muted small">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-4">
        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-trophy me-2 text-warning"></i>Bánh bán chạy</h5>
            @if (!Model.TopProducts.Any())
            {
                <p class="text-muted">Chưa có dữ liệu.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @{ int rank = 1; }
                    @foreach (var tp in Model.TopProducts)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge rounded-pill @(rank <= 3 ? "bg-warning text-dark" : "bg-secondary") px-2">@rank</span>
                            <div class="flex-grow-1">
                                <div class="fw-semibold small">@tp.ProductName</div>
                                <div class="text-muted" style="font-size:.75rem">@tp.TotalSold SP – @tp.TotalRevenue.ToString("N0")₫</div>
                            </div>
                        </div>
                        rank++;
                    }
                </div>
            }
        </div>

        <div class="admin-card p-4 mt-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-wallet2 me-2 text-success"></i>Hôm nay</h5>
            <div class="text-center">
                <div class="stat-value" style="font-size:2rem;color:#2e7d32">@Model.TodayRevenue.ToString("N0")₫</div>
                <div class="stat-label">Doanh thu hôm nay</div>
            </div>
        </div>
    </div>
</div>
