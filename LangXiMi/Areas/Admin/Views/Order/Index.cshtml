@model List<LangXiMi.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">Tổng: <strong>@Model.Count</strong> đơn hàng</p>
</div>

<div class="admin-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    var badgeClass = o.Status switch {
                        "Chờ xác nhận" => "badge-cho-xac-nhan",
                        "Đang làm" => "badge-dang-lam",
                        "Đang giao hàng" => "badge-dang-giao",
                        "Hoàn thành" => "badge-hoan-thanh",
                        "Đã hủy" => "badge-da-huy",
                        _ => ""
                    };
                    <tr>
                        <td class="fw-bold">#@o.OrderId</td>
                        <td>@o.Customer?.FullName</td>
                        <td class="text-muted">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end fw-semibold">@o.TotalAmount.ToString("N0")₫</td>
                        <td class="text-center"><span class="badge-status @badgeClass">@o.Status</span></td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
