@model LangXiMi.Models.AdminEmployeeViewModel
@{
    ViewData["Title"] = Model.EmployeeId == 0 ? "Thêm nhân viên" : "Sửa nhân viên";
    var isEdit = Model.EmployeeId != 0;
}

<a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card p-4">
            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                @Html.AntiForgeryToken()
                @if (isEdit) { <input type="hidden" asp-for="EmployeeId" /> }

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="MaNhanVien" class="form-label fw-semibold"></label>
                        <input asp-for="MaNhanVien" class="form-control" placeholder="NV001" readonly="@isEdit" />
                        <span asp-validation-for="MaNhanVien" class="text-danger small"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CCCD" class="form-label fw-semibold"></label>
                        <input asp-for="CCCD" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Position" class="form-label fw-semibold"></label>
                        <select asp-for="Position" asp-items="Html.GetEnumSelectList<LangXiMi.Models.EmployeePosition>()" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TrangThai" class="form-label fw-semibold"></label>
                        <select asp-for="TrangThai" asp-items="Html.GetEnumSelectList<LangXiMi.Models.EmployeeStatus>()" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NgayVaoLam" class="form-label fw-semibold"></label>
                        <input asp-for="NgayVaoLam" class="form-control" type="date" />
                    </div>
                </div>

                @if (!isEdit)
                {
                    <hr />
                    <h6 class="fw-bold mb-3"><i class="bi bi-key me-2"></i>Tài khoản đăng nhập</h6>
                    <div class="form-check mb-3">
                        <input asp-for="CreateAccount" class="form-check-input" id="chkCreateAccount" />
                        <label asp-for="CreateAccount" class="form-check-label">Cấp tài khoản đăng nhập cho nhân viên này</label>
                    </div>
                    <div id="accountFields" style="display:none">
                        <div class="col-md-6">
                            <label asp-for="AccountPassword" class="form-label fw-semibold"></label>
                            <input asp-for="AccountPassword" class="form-control" />
                            <span asp-validation-for="AccountPassword" class="text-danger small"></span>
                            <div class="form-text">Email ở trên sẽ được dùng làm tài khoản đăng nhập.</div>
                        </div>
                    </div>
                }

                <hr />
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi @(isEdit ? "bi-save" : "bi-person-plus") me-1"></i>@(isEdit ? "Lưu thay đổi" : "Thêm nhân viên")
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const chk = document.getElementById('chkCreateAccount');
        const fields = document.getElementById('accountFields');
        if (chk && fields) {
            chk.addEventListener('change', () => fields.style.display = chk.checked ? 'block' : 'none');
            if (chk.checked) fields.style.display = 'block';
        }
    </script>
}
