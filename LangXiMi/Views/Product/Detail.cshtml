@model LangXiMi.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Thực đơn</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.Category?.CategoryName</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- Product Image -->
        <div class="col-lg-6">
            <div class="lxm-card overflow-hidden">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.jpg" : Model.ImageUrl)"
                     alt="@Model.ProductName" class="w-100" style="height:420px;object-fit:cover" />
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6">
            <span class="lxm-category-tag mb-2 d-inline-block">@Model.Category?.CategoryName</span>
            <h1 class="lxm-page-title" style="border:none;padding:0">@Model.ProductName</h1>

            <div class="lxm-price fs-2 my-3">@Model.Price.ToString("N0")₫</div>

            <!-- Stock Status -->
            <div class="mb-4">
                @if (Model.StockQuantity == 0)
                {
                    <span class="badge bg-danger px-3 py-2"><i class="bi bi-x-circle me-1"></i>Hết hàng</span>
                }
                else if (Model.StockQuantity <= 5)
                {
                    <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-exclamation-triangle me-1"></i>Sắp hết – còn @Model.StockQuantity</span>
                }
                else
                {
                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i>Còn hàng (@Model.StockQuantity)</span>
                }
            </div>

            <!-- Add to cart form -->
            @if (Model.StockQuantity > 0)
            {
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="form-add-to-cart">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <label class="fw-semibold">Số lượng:</label>
                        <div class="input-group" style="width:140px">
                            <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">−</button>
                            <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="@Model.StockQuantity"
                                   class="form-control text-center" style="font-weight:600" />
                            <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg px-5 lxm-order-btn">
                        <i class="bi bi-bag-plus me-2"></i>Thêm vào giỏ hàng
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary btn-lg" disabled>
                    <i class="bi bi-bag-x me-2"></i>Tạm hết hàng
                </button>
            }

            <!-- Info badges -->
            <div class="mt-4 pt-4 border-top">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <i class="bi bi-truck fs-5 text-primary"></i>
                            <span>Giao hàng trong ngày</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <i class="bi bi-shield-check fs-5 text-success"></i>
                            <span>Nguyên liệu tươi sạch</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <i class="bi bi-arrow-counterclockwise fs-5 text-warning"></i>
                            <span>Đổi trả trong 24h</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <i class="bi bi-telephone fs-5 text-info"></i>
                            <span>Hỗ trợ 0901 234 567</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            let val = parseInt(input.value) + delta;
            val = Math.max(parseInt(input.min), Math.min(parseInt(input.max), val));
            input.value = val;
        }
    </script>
}
