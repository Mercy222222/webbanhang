@model LangXiMi.Models.ProductCatalogViewModel
@{
    ViewData["Title"] = "Thực đơn bánh ngọt";
}

<!-- HERO BANNER -->
<section class="lxm-hero py-5">
    <div class="container text-center py-3">
        <h1 class="lxm-hero-title">🍰 Thực đơn Làng Xì Mi</h1>
        <p class="lxm-hero-sub">Bánh ngọt thủ công – làm mới mỗi ngày từ nguyên liệu tươi tốt nhất</p>
    </div>
</section>

<div class="container my-5">
    <div class="row g-4">

        <!-- ── SIDEBAR: Danh mục + Tìm kiếm ── -->
        <aside class="col-lg-3">
            <!-- Search -->
            <div class="lxm-card p-4 mb-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-search me-2 text-primary"></i>Tìm kiếm</h6>
                <form asp-action="Index" method="get" id="searchForm">
                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    <div class="input-group">
                        <input type="text" class="form-control" name="search"
                               value="@Model.SearchKeyword" placeholder="Tên bánh..." id="searchInput" />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Categories -->
            <div class="lxm-card p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-tags me-2 text-primary"></i>Danh mục</h6>
                <div class="d-flex flex-column gap-2">
                    <a asp-action="Index" asp-route-search="@Model.SearchKeyword"
                       class="lxm-cat-link @(Model.SelectedCategoryId == null ? "active" : "")">
                        <i class="bi bi-grid me-2"></i>Tất cả (@Model.Products.Count)
                    </a>
                    @foreach (var cat in Model.Categories)
                    {
                        var count = Model.Products.Count(p => p.CategoryId == cat.CategoryId);
                        <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                           asp-route-search="@Model.SearchKeyword"
                           class="lxm-cat-link @(Model.SelectedCategoryId == cat.CategoryId ? "active" : "")">
                            <i class="bi bi-tag me-2"></i>@cat.CategoryName
                            <span class="badge bg-light text-dark ms-auto">@count</span>
                        </a>
                    }
                </div>
            </div>
        </aside>

        <!-- ── MAIN: Lưới sản phẩm ── -->
        <div class="col-lg-9">

            <!-- Kết quả lọc -->
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <span class="text-muted">
                        Hiển thị <strong>@Model.Products.Count</strong> sản phẩm
                        @if (!string.IsNullOrEmpty(Model.SearchKeyword))
                        {
                            <span> cho từ khóa "<strong>@Model.SearchKeyword</strong>"</span>
                        }
                        @if (Model.SelectedCategoryId.HasValue)
                        {
                            var catName = Model.Categories.FirstOrDefault(c => c.CategoryId == Model.SelectedCategoryId)?.CategoryName;
                            <span> trong "<strong>@catName</strong>"</span>
                        }
                    </span>
                </div>
                @if (Model.SelectedCategoryId.HasValue || !string.IsNullOrEmpty(Model.SearchKeyword))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
                    </a>
                }
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-emoji-frown display-1 text-muted opacity-25"></i>
                    <h5 class="mt-3 text-muted">Không tìm thấy sản phẩm</h5>
                    <a asp-action="Index" class="btn btn-primary mt-2">Xem tất cả bánh</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var p in Model.Products)
                    {
                        <div class="col-sm-6 col-xl-4">
                            <div class="lxm-product-card h-100">
                                <!-- Ảnh sản phẩm -->
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId"
                                   class="d-block lxm-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/images/no-image.jpg" : p.ImageUrl)"
                                         alt="@p.ProductName" class="lxm-product-img" />
                                    @if (p.StockQuantity == 0)
                                    {
                                        <span class="lxm-badge-soldout">Hết hàng</span>
                                    }
                                    else if (p.StockQuantity <= 5)
                                    {
                                        <span class="lxm-badge-low">Sắp hết (@p.StockQuantity)</span>
                                    }
                                </a>

                                <div class="lxm-product-body">
                                    <span class="lxm-category-tag">@p.Category?.CategoryName</span>
                                    <h5 class="lxm-product-name mt-1">@p.ProductName</h5>
                                    <div class="d-flex align-items-center justify-content-between mt-3">
                                        <span class="lxm-price">@p.Price.ToString("N0")₫</span>
                                        @if (p.StockQuantity > 0)
                                        {
                                            <form asp-controller="Order" asp-action="AddToCart" method="post" class="d-inline form-add-to-cart">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@p.ProductId" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button type="submit" class="btn btn-primary btn-sm lxm-add-btn" 
                                                        title="Thêm vào giỏ">
                                                    <i class="bi bi-bag-plus"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled>
                                                <i class="bi bi-bag-x"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
