@model List<LangXiMi.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal grandTotal = Model?.Sum(i => i.LineTotal) ?? 0;
    int totalItems = Model?.Sum(i => i.Quantity) ?? 0;
}

<div class="container my-5">
    <div class="d-flex align-items-center mb-4">
        <h2 class="lxm-page-title mb-0"><i class="bi bi-bag-heart me-2"></i>Giỏ hàng của bạn</h2>
        @if (Model != null && Model.Any())
        {
            <span class="badge bg-primary ms-3 fs-6">@totalItems sản phẩm</span>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="lxm-card p-5 text-center">
            <div class="mb-4">
                <i class="bi bi-bag display-1 text-muted" style="opacity:0.2"></i>
            </div>
            <h4 class="text-muted mb-2">Giỏ hàng đang trống</h4>
            <p class="text-muted mb-4">Hãy khám phá thực đơn và thêm bánh vào giỏ nhé!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-grid me-2"></i>Khám phá thực đơn
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Danh sách sản phẩm -->
            <div class="col-lg-8">
                <div class="lxm-card p-0 overflow-hidden">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr style="background: linear-gradient(135deg, #3d2c2c, #5a3e3e); color:white;">
                                <th class="px-4 py-3">Sản phẩm</th>
                                <th class="text-center py-3">Đơn giá</th>
                                <th class="text-center py-3" style="min-width:140px">Số lượng</th>
                                <th class="text-center py-3">Thành tiền</th>
                                <th class="text-center py-3" style="width:60px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr id="row-@item.ProductId">
                                    <td class="px-4 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.jpg" : item.ImageUrl)"
                                                 alt="@item.ProductName" class="rounded-3 shadow-sm"
                                                 style="width:70px;height:70px;object-fit:cover" />
                                            <div>
                                                <span class="fw-semibold d-block">@item.ProductName</span>
                                                <small class="text-muted">@item.CategoryName</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center text-muted">@item.UnitPrice.ToString("N0")₫</td>
                                    <td class="text-center">
                                        <div class="d-inline-flex align-items-center border rounded-pill overflow-hidden" style="background:#f8f9fa;">
                                            <button type="button" class="btn btn-sm btn-qty px-3 py-1 border-0"
                                                    data-product-id="@item.ProductId" data-action="decrease"
                                                    style="background:transparent; font-weight:bold; font-size:1.1rem; line-height:1;">
                                                −
                                            </button>
                                            <span id="qty-@item.ProductId" class="px-3 fw-bold" style="min-width:30px; text-align:center;">@item.Quantity</span>
                                            <button type="button" class="btn btn-sm btn-qty px-3 py-1 border-0"
                                                    data-product-id="@item.ProductId" data-action="increase"
                                                    style="background:transparent; font-weight:bold; font-size:1.1rem; line-height:1;">
                                                +
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span id="line-total-@item.ProductId" class="fw-bold text-primary">@item.LineTotal.ToString("N0")₫</span>
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle"
                                                    style="width:36px;height:36px;padding:0;"
                                                    title="Xóa" id="removeItem_@item.ProductId"
                                                    onclick="return confirm('Xóa @item.ProductName khỏi giỏ hàng?')">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- Tổng đơn hàng -->
            <div class="col-lg-4">
                <div class="lxm-card p-4" style="position:sticky; top:100px;">
                    <h5 class="fw-bold mb-4"><i class="bi bi-receipt me-2 text-primary"></i>Tóm tắt đơn hàng</h5>

                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Số lượng sản phẩm</span>
                        <span id="item-count">@totalItems</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Tạm tính</span>
                        <span id="subtotal">@grandTotal.ToString("N0")₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Phí giao hàng</span>
                        <span class="text-success fw-semibold">Miễn phí</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Tổng cộng</span>
                        <span class="text-primary" id="grand-total">@grandTotal.ToString("N0")₫</span>
                    </div>

                    <a asp-controller="Order" asp-action="Checkout"
                       class="btn btn-primary w-100 py-3 fw-bold shadow-sm" id="btnCheckout"
                       style="border-radius:12px; font-size:1.05rem;">
                        <i class="bi bi-credit-card me-2"></i>Tiến hành đặt hàng
                    </a>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            <i class="bi bi-shield-check me-1"></i>Thanh toán an toàn & bảo mật
                        </small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
