@model LangXiMi.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Đặt hàng";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Thực đơn</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Cart">Giỏ hàng</a></li>
                    <li class="breadcrumb-item active">Thanh toán</li>
                </ol>
            </nav>

            <h1 class="lxm-page-title mb-4"><i class="bi bi-clipboard-check me-2"></i>Xác nhận đặt hàng</h1>
        </div>
    </div>

    <form asp-action="Checkout" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()

        <!-- Validation summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>Vui lòng kiểm tra lại:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">

            <!-- ── CỘT TRÁI: Thông tin khách hàng ── -->
            <div class="col-lg-7">
                <div class="lxm-card p-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-person-circle me-2 text-primary"></i>Thông tin người nhận
                    </h5>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Thị Lan" id="inputFullName" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" id="inputEmail" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-phone"></i></span>
                            <input asp-for="Phone" class="form-control" placeholder="09xxxxxxxx" id="inputPhone" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Address" class="form-control" placeholder="Số nhà, đường, phường, quận..." id="inputAddress" />
                        </div>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Note" class="form-label fw-semibold">
                            Ghi chú <span class="text-muted fw-normal">(tuỳ chọn)</span>
                        </label>
                        <textarea asp-for="Note" class="form-control" rows="3"
                                  placeholder="Ví dụ: Giao giờ hành chính, gọi trước khi đến..." id="inputNote"></textarea>
                    </div>
                </div>
            </div>

            <!-- ── CỘT PHẢI: Tóm tắt đơn hàng ── -->
            <div class="col-lg-5">
                <div class="lxm-card p-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-receipt me-2 text-primary"></i>Đơn hàng của bạn
                    </h5>

                    @if (!Model.CartItems.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-bag display-4 opacity-25"></i>
                            <p class="mt-2">Giỏ hàng trống</p>
                        </div>
                    }
                    else
                    {
                        <div class="lxm-order-items">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.jpg" : item.ImageUrl)"
                                         alt="@item.ProductName" class="rounded" style="width:54px;height:54px;object-fit:cover" />
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small">@item.ProductName</div>
                                        <div class="text-muted small">SL: @item.Quantity × @item.UnitPrice.ToString("N0")₫</div>
                                    </div>
                                    <div class="fw-bold text-primary">@item.LineTotal.ToString("N0")₫</div>
                                </div>
                            }
                        </div>

                        <!-- Tổng cộng -->
                        <div class="mt-3 pt-3">
                            <div class="d-flex justify-content-between mb-1 text-muted small">
                                <span>Tạm tính</span>
                                <span>@Model.GrandTotal.ToString("N0")₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1 text-muted small">
                                <span>Phí giao hàng</span>
                                <span class="text-success">Miễn phí</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <span>Tổng cộng</span>
                                <span class="text-primary">@Model.GrandTotal.ToString("N0")₫</span>
                            </div>
                        </div>

                        <!-- Nút đặt hàng -->
                        <button type="submit" class="btn btn-primary w-100 mt-4 py-3 fw-bold lxm-order-btn" id="btnPlaceOrder">
                            <i class="bi bi-bag-check me-2"></i>Đặt hàng ngay
                        </button>
                        <a asp-controller="Order" asp-action="Cart" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại giỏ hàng
                        </a>

                        <!-- Cam kết -->
                        <div class="mt-4 pt-3 border-top">
                            <div class="d-flex gap-2 mb-2 small text-muted">
                                <i class="bi bi-shield-check text-success fs-5"></i>
                                <span>Thông tin được bảo mật tuyệt đối</span>
                            </div>
                            <div class="d-flex gap-2 small text-muted">
                                <i class="bi bi-truck text-primary fs-5"></i>
                                <span>Giao hàng trong ngày tại TP.HCM</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Disable button sau khi submit để tránh double-click
        document.getElementById('checkoutForm')?.addEventListener('submit', function () {
            const btn = document.getElementById('btnPlaceOrder');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            }
        });
    </script>
}
