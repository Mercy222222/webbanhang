@model LangXiMi.Models.OrderConfirmationViewModel
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="lxm-card p-5 text-center">
                <!-- Animation icon -->
                <div class="lxm-success-icon mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size:5rem"></i>
                </div>

                <h1 class="h2 fw-bold mb-2">Đặt hàng thành công! 🎉</h1>
                <p class="text-muted mb-4">
                    Cảm ơn <strong>@Model.CustomerName</strong>! Chúng tôi sẽ liên hệ sớm để xác nhận đơn.
                </p>

                <!-- Chi tiết đơn hàng -->
                <div class="lxm-confirm-box text-start p-4 rounded-3 mb-4">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="text-muted small mb-1">Mã đơn hàng</div>
                            <div class="fw-bold fs-5 text-primary">#@Model.OrderId</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small mb-1">Trạng thái</div>
                            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                                <i class="bi bi-hourglass-split me-1"></i>@Model.Status
                            </span>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small mb-1">Ngày đặt</div>
                            <div class="fw-semibold">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small mb-1">Tổng tiền</div>
                            <div class="fw-bold fs-5 text-primary">@Model.TotalAmount.ToString("N0")₫</div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin giao hàng -->
                <div class="alert alert-info text-start py-3">
                    <i class="bi bi-info-circle me-2"></i>
                    Nhân viên sẽ gọi xác nhận trong vòng <strong>30 phút</strong>.
                    Đơn hàng sẽ được giao trong <strong>2-4 giờ</strong> sau khi xác nhận.
                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary px-4">
                        <i class="bi bi-grid me-2"></i>Tiếp tục mua sắm
                    </a>
                    <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-clock-history me-2"></i>Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Confetti effect nhỏ khi load trang thành công
    document.addEventListener('DOMContentLoaded', function () {
        const icon = document.querySelector('.lxm-success-icon');
        icon.style.animation = 'bounceIn 0.6s ease';
    });
</script>
}
