{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start 9Router Control Panel",
            "type": "shell",
            "command": "cmd.exe /c \\\"cd 9router-control-panel && 9router-start-admin-pro-gui-v5.4.bat\\\"",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Start Elite Fleet Chatbot",
            "type": "shell",
            "command": "node scripts/chat-cli.js",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": true,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
