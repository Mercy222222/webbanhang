							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has success true\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"});",
									"",
									"pm.test(\"Data is an array\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Array is not empty\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test(\"Each product has id, name, price\", function () {",
									"    const json = pm.response.json();",
									"    json.data.forEach(function(p) {",
									"        pm.expect(p).to.have.property('id');",
									"        pm.expect(p).to.have.property('name');",
									"        pm.expect(p).to.have.property('price');",
									"    });",
									"});",
									"",
									"pm.test(\"Response time is less than 500ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
